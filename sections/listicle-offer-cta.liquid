{%- render 'section-spacing-collapsing' -%}

<style>
  #shopify-section-{{ section.id }} {
    --padding-top: {{ section.settings.padding_top_desktop }}px;
    --padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      --padding-top: {{ section.settings.padding_top_mobile }}px;
      --padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }

  #shopify-section-{{ section.id }} .listicle-offer-cta {
    padding-block-start: var(--padding-top);
    padding-block-end: var(--padding-bottom);
    display: flex;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .listicle-offer-cta__card {
    background: #ffffff;
    border: 3px dashed #182153;
    border-radius: 32px;
    padding: 32px;
    width: 100%;
    max-width: 800px;
    display: flex;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .listicle-offer-cta__inner {
    display: flex;
    flex-direction: column;
    gap: 32px;
    width: 100%;
    max-width: 520px;
  }

  /* Header */
  #shopify-section-{{ section.id }} .listicle-offer-cta__header {
    display: flex;
    flex-direction: column;
    gap: 4px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .listicle-offer-cta__subtext-wrap {
    margin-top: 16px;
  }

  #shopify-section-{{ section.id }} .listicle-offer-cta__eyebrow {
    font-family: var(--text-font-family);
    font-size: 20px;
    font-weight: 400;
    line-height: 1.5;
    color: #8a2f3a;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .listicle-offer-cta__heading {
    font-family: var(--heading-font-family);
    font-size: 40px;
    font-weight: 500;
    line-height: 1.2;
    color: #182153;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .listicle-offer-cta__subtext {
    font-family: var(--text-font-family);
    font-size: 16px;
    line-height: 1.5;
    color: rgba(24, 33, 83, 0.75);
    text-align: center;
  }

  #shopify-section-{{ section.id }} .listicle-offer-cta__subtext p {
    margin: 0;
  }

  /* Divider */
  #shopify-section-{{ section.id }} .listicle-offer-cta__divider {
    height: 1px;
    background: rgba(24, 33, 83, 0.08);
  }

  /* Image */
  #shopify-section-{{ section.id }} .listicle-offer-cta__image {
    width: 100%;
    height: 280px;
    border-radius: 24px;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .listicle-offer-cta__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Features */
  #shopify-section-{{ section.id }} .listicle-offer-cta__features {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  #shopify-section-{{ section.id }} .listicle-offer-cta__feature {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .listicle-offer-cta__feature-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .listicle-offer-cta__feature-text {
    font-family: var(--text-font-family);
    font-size: 14px;
    font-weight: 600;
    line-height: 1.5;
    color: #182153;
    margin: 0;
  }

  /* CTA area */
  #shopify-section-{{ section.id }} .listicle-offer-cta__cta {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  #shopify-section-{{ section.id }} .listicle-offer-cta__button {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #232e71;
    color: #fdfbf9;
    height: 52px;
    border-radius: 999px;
    padding-inline: 32px;
    font-family: var(--text-font-family);
    font-size: 14px;
    font-weight: 600;
    line-height: 1;
    text-transform: uppercase;
    text-decoration: none;
    width: 100%;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  #shopify-section-{{ section.id }} .listicle-offer-cta__button:hover {
    opacity: 0.9;
  }

  /* Trust badges */
  #shopify-section-{{ section.id }} .listicle-offer-cta__trust {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  #shopify-section-{{ section.id }} .listicle-offer-cta__trust-item {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .listicle-offer-cta__trust-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .listicle-offer-cta__trust-text {
    font-family: var(--text-font-family);
    font-size: 14px;
    font-weight: 600;
    line-height: 1.5;
    color: #182153;
    margin: 0;
  }

  /* Mobile */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .listicle-offer-cta {
      padding-inline: 20px;
    }

    #shopify-section-{{ section.id }} .listicle-offer-cta__card {
      padding: 12px 16px;
      border-radius: 24px;
      border-width: 2px;
      max-width: 100%;
    }

    #shopify-section-{{ section.id }} .listicle-offer-cta__inner {
      max-width: 100%;
    }

    #shopify-section-{{ section.id }} .listicle-offer-cta__eyebrow {
      font-size: 16px;
    }

    #shopify-section-{{ section.id }} .listicle-offer-cta__heading {
      font-size: 32px;
    }

    #shopify-section-{{ section.id }} .listicle-offer-cta__image {
      border-radius: 16px;
    }
  }
</style>

<div {% render 'section-properties' %}>
  <div class="listicle-offer-cta container">
    <div class="listicle-offer-cta__card">
      <div class="listicle-offer-cta__inner">

        {%- liquid
          assign has_features = false
          if section.settings.feature_1 != blank or section.settings.feature_2 != blank or section.settings.feature_3 != blank or section.settings.feature_4 != blank
            assign has_features = true
          endif
        -%}

        <!-- Header -->
        {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subtext != blank -%}
          <div class="listicle-offer-cta__header">
            {%- if section.settings.eyebrow != blank -%}
              <p class="listicle-offer-cta__eyebrow">{{ section.settings.eyebrow | escape }}</p>
            {%- endif -%}
            {%- if section.settings.heading != blank -%}
              <h2 class="listicle-offer-cta__heading">{{ section.settings.heading | escape }}</h2>
            {%- endif -%}
            {%- if section.settings.subtext != blank -%}
              <div class="listicle-offer-cta__subtext listicle-offer-cta__subtext-wrap">{{ section.settings.subtext }}</div>
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="listicle-offer-cta__divider"></div>

        <!-- Image -->
        {%- if section.settings.image != blank -%}
          <div class="listicle-offer-cta__image">
            {{-
              section.settings.image
              | image_url: width: section.settings.image.width
              | image_tag:
                loading: 'lazy',
                sizes: '(max-width: 749px) calc(100vw - 64px), 520px',
                widths: '400,600,800,1000',
                alt: section.settings.image.alt | escape
            -}}
          </div>
        {%- endif -%}

        <!-- Features -->
        {%- if has_features -%}
          <div class="listicle-offer-cta__features">
            {%- if section.settings.feature_1 != blank -%}
              <div class="listicle-offer-cta__feature">
                {%- if section.settings.feature_1_icon != blank -%}
                  {{- section.settings.feature_1_icon | image_url: width: 40 | image_tag: class: 'listicle-offer-cta__feature-icon', loading: 'lazy', alt: '' -}}
                {%- else -%}
                  <svg class="listicle-offer-cta__feature-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <circle cx="10" cy="10" r="10" fill="#232e71"/>
                    <path d="M6 10l3 3 5-5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {%- endif -%}
                <p class="listicle-offer-cta__feature-text">{{ section.settings.feature_1 | escape }}</p>
              </div>
            {%- endif -%}
            {%- if section.settings.feature_2 != blank -%}
              <div class="listicle-offer-cta__feature">
                {%- if section.settings.feature_2_icon != blank -%}
                  {{- section.settings.feature_2_icon | image_url: width: 40 | image_tag: class: 'listicle-offer-cta__feature-icon', loading: 'lazy', alt: '' -}}
                {%- else -%}
                  <svg class="listicle-offer-cta__feature-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <circle cx="10" cy="10" r="10" fill="#232e71"/>
                    <path d="M6 10l3 3 5-5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {%- endif -%}
                <p class="listicle-offer-cta__feature-text">{{ section.settings.feature_2 | escape }}</p>
              </div>
            {%- endif -%}
            {%- if section.settings.feature_3 != blank -%}
              <div class="listicle-offer-cta__feature">
                {%- if section.settings.feature_3_icon != blank -%}
                  {{- section.settings.feature_3_icon | image_url: width: 40 | image_tag: class: 'listicle-offer-cta__feature-icon', loading: 'lazy', alt: '' -}}
                {%- else -%}
                  <svg class="listicle-offer-cta__feature-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <circle cx="10" cy="10" r="10" fill="#232e71"/>
                    <path d="M6 10l3 3 5-5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {%- endif -%}
                <p class="listicle-offer-cta__feature-text">{{ section.settings.feature_3 | escape }}</p>
              </div>
            {%- endif -%}
            {%- if section.settings.feature_4 != blank -%}
              <div class="listicle-offer-cta__feature">
                {%- if section.settings.feature_4_icon != blank -%}
                  {{- section.settings.feature_4_icon | image_url: width: 40 | image_tag: class: 'listicle-offer-cta__feature-icon', loading: 'lazy', alt: '' -}}
                {%- else -%}
                  <svg class="listicle-offer-cta__feature-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <circle cx="10" cy="10" r="10" fill="#232e71"/>
                    <path d="M6 10l3 3 5-5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {%- endif -%}
                <p class="listicle-offer-cta__feature-text">{{ section.settings.feature_4 | escape }}</p>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

        <!-- CTA + trust -->
        <div class="listicle-offer-cta__cta">
          {%- if section.settings.button_label != blank -%}
            {%- if section.settings.button_url != blank -%}
              <a href="{{ section.settings.button_url }}" class="listicle-offer-cta__button">
                {{- section.settings.button_label | escape -}}
              </a>
            {%- else -%}
              <button type="button" class="listicle-offer-cta__button">
                {{- section.settings.button_label | escape -}}
              </button>
            {%- endif -%}
          {%- endif -%}

          <div class="listicle-offer-cta__trust">
            {%- if section.settings.trust_1 != blank -%}
              <div class="listicle-offer-cta__trust-item">
                {%- if section.settings.trust_1_icon != blank -%}
                  {{- section.settings.trust_1_icon | image_url: width: 32 | image_tag: class: 'listicle-offer-cta__trust-icon', loading: 'lazy', alt: '' -}}
                {%- else -%}
                  <svg class="listicle-offer-cta__trust-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M2 5.5l6-3 6 3v5l-6 3-6-3v-5z" stroke="#182153" stroke-width="1.2" stroke-linejoin="round"/>
                    <path d="M2 5.5l6 3 6-3M8 8.5V14" stroke="#182153" stroke-width="1.2" stroke-linecap="round"/>
                    <path d="M5 4l6 3" stroke="#182153" stroke-width="1.2" stroke-linecap="round"/>
                  </svg>
                {%- endif -%}
                <p class="listicle-offer-cta__trust-text">{{ section.settings.trust_1 | escape }}</p>
              </div>
            {%- endif -%}
            {%- if section.settings.trust_2 != blank -%}
              <div class="listicle-offer-cta__trust-item">
                {%- if section.settings.trust_2_icon != blank -%}
                  {{- section.settings.trust_2_icon | image_url: width: 32 | image_tag: class: 'listicle-offer-cta__trust-icon', loading: 'lazy', alt: '' -}}
                {%- else -%}
                  <svg class="listicle-offer-cta__trust-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M2 5h8a3 3 0 0 1 0 6H6" stroke="#182153" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M4 3L2 5l2 2" stroke="#182153" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {%- endif -%}
                <p class="listicle-offer-cta__trust-text">{{ section.settings.trust_2 | escape }}</p>
              </div>
            {%- endif -%}
            {%- if section.settings.trust_3 != blank -%}
              <div class="listicle-offer-cta__trust-item">
                {%- if section.settings.trust_3_icon != blank -%}
                  {{- section.settings.trust_3_icon | image_url: width: 32 | image_tag: class: 'listicle-offer-cta__trust-icon', loading: 'lazy', alt: '' -}}
                {%- else -%}
                  <svg class="listicle-offer-cta__trust-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M1 3h9v7H1V3z" stroke="#182153" stroke-width="1.2" stroke-linejoin="round"/>
                    <path d="M10 6h2l2 2.5V10h-4V6z" stroke="#182153" stroke-width="1.2" stroke-linejoin="round"/>
                    <circle cx="4" cy="11" r="1.2" stroke="#182153" stroke-width="1.1"/>
                    <circle cx="12" cy="11" r="1.2" stroke="#182153" stroke-width="1.1"/>
                  </svg>
                {%- endif -%}
                <p class="listicle-offer-cta__trust-text">{{ section.settings.trust_3 | escape }}</p>
              </div>
            {%- endif -%}
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

{% schema %}
