    },
    {
      "type": "image_picker",
      "id": "feature_2_icon",
      "label": "Feature 2 icon",
      "info": "20×20px. Defaults to checkmark if empty."
    },
    {
      "type": "text",
      "id": "feature_2",
      "label": "Feature 2"
    },
    {
      "type": "image_picker",
      "id": "feature_3_icon",
      "label": "Feature 3 icon",
      "info": "20×20px. Defaults to checkmark if empty."
    },
    {
      "type": "text",
      "id": "feature_3",
      "label": "Feature 3"
    },
    {
      "type": "image_picker",
      "id": "feature_4_icon",
      "label": "Feature 4 icon",
