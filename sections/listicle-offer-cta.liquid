      "label": "Trust item 2 icon",
      "info": "16×16px. Defaults to return icon if empty."
    },
    {
      "type": "text",
      "id": "trust_2",
      "label": "Trust item 2"
    },
    {
      "type": "image_picker",
      "id": "trust_3_icon",
