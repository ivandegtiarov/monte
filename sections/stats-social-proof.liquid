<style>
  #shopify-section-{{ section.id }} {
    padding: 0;
  }

  .stats-proof-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    padding-left: 0;
    padding-right: 0;
  }

  .stats-proof-{{ section.id }} .stats-proof__inner {
    max-width: 1360px;
    margin: 0 auto;
    padding-left: 20px;
    padding-right: 20px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* Image */
  .stats-proof-{{ section.id }} .stats-proof__image-wrap {
    width: 100%;
    border-radius: 16px;
    overflow: hidden;
    background-color: #fbf7f3;
    aspect-ratio: 1 / 1;
  }

  .stats-proof-{{ section.id }} .stats-proof__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    mix-blend-mode: luminosity;
    display: block;
  }

  /* Content */
  .stats-proof-{{ section.id }} .stats-proof__content {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* Text block */
  .stats-proof-{{ section.id }} .stats-proof__text-block {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .stats-proof-{{ section.id }} .stats-proof__tagline {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: "PP Neue Montreal Mono", monospace;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: {{ section.settings.tagline_color }};
    line-height: 1.5;
  }

  .stats-proof-{{ section.id }} .stats-proof__tagline-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background-color: currentColor;
    flex-shrink: 0;
  }

  .stats-proof-{{ section.id }} .stats-proof__heading {
    font-family: "PP Pangaia", serif;
    font-size: 24px;
    font-weight: 500;
    color: {{ section.settings.heading_color }};
    line-height: 1.4;
    margin: 0;
  }

  .stats-proof-{{ section.id }} .stats-proof__heading em {
    font-style: italic;
  }

  .stats-proof-{{ section.id }} .stats-proof__body {
    font-family: "PP Mori", sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: {{ section.settings.body_color }};
    line-height: 1.5;
    margin: 0;
  }

  /* Stats */
  .stats-proof-{{ section.id }} .stats-proof__stats {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .stats-proof-{{ section.id }} .stats-proof__stat-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(24, 33, 83, 0.08);
  }

  .stats-proof-{{ section.id }} .stats-proof__stat-number {
    font-family: "PP Pangaia", serif;
    font-size: 20px;
    font-weight: 500;
    color: {{ section.settings.heading_color }};
    line-height: 1.4;
    white-space: nowrap;
  }

  .stats-proof-{{ section.id }} .stats-proof__stat-label {
    font-family: "PP Mori", sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: {{ section.settings.body_color }};
    line-height: 1.5;
    flex: 1;
    text-align: right;
  }

  .stats-proof-{{ section.id }} .stats-proof__footnote {
    font-family: "PP Mori", sans-serif;
    font-size: 12px;
    font-weight: 400;
    color: {{ section.settings.body_color }};
    line-height: 1.5;
    margin: 0;
  }

  /* Feature items block */
  .stats-proof-{{ section.id }} .stats-proof__features {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .stats-proof-{{ section.id }} .stats-proof__feature-item {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
  }

  .stats-proof-{{ section.id }} .stats-proof__feature-icon {
    width: 16px;
    height: 16px;
    border-radius: 999px;
    background-color: #232e71;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .stats-proof-{{ section.id }} .stats-proof__feature-icon svg {
    width: 9px;
    height: 9px;
  }

  .stats-proof-{{ section.id }} .stats-proof__feature-text {
    font-family: "PP Mori", sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: {{ section.settings.heading_color }};
    line-height: 1.5;
    flex: 1;
    min-width: 1px;
  }

  /* Review card block */
  .stats-proof-{{ section.id }} .stats-proof__review-card {
    background-color: #fbf7f3;
    border-radius: 12px;
    padding: 16px;
    display: flex;
    flex-direction: row;
    gap: 16px;
    overflow: hidden;
  }

  .stats-proof-{{ section.id }} .stats-proof__review-image {
    width: 64px;
    height: 64px;
    border-radius: 8px;
    overflow: hidden;
    background-color: #eee7e0;
    flex-shrink: 0;
  }

  .stats-proof-{{ section.id }} .stats-proof__review-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    mix-blend-mode: luminosity;
    display: block;
  }

  .stats-proof-{{ section.id }} .stats-proof__review-content {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  .stats-proof-{{ section.id }} .stats-proof__stars {
    display: flex;
    flex-direction: row;
    gap: 2px;
  }

  .stats-proof-{{ section.id }} .stats-proof__star {
    width: 12px;
    height: 12px;
    color: #d9a17d;
  }

  .stats-proof-{{ section.id }} .stats-proof__review-quote {
    font-family: "PP Mori", sans-serif;
    font-size: 12px;
    font-weight: 400;
    color: {{ section.settings.body_color }};
    line-height: 1.5;
    margin: 0;
  }

  .stats-proof-{{ section.id }} .stats-proof__review-attribution {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
  }

  .stats-proof-{{ section.id }} .stats-proof__review-name {
    font-family: "PP Mori", sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: {{ section.settings.heading_color }};
    line-height: 1.5;
    white-space: nowrap;
  }

  .stats-proof-{{ section.id }} .stats-proof__review-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background-color: rgba(24, 33, 83, 0.3);
    flex-shrink: 0;
  }

  .stats-proof-{{ section.id }} .stats-proof__verified {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 6px;
    overflow: hidden;
  }

  .stats-proof-{{ section.id }} .stats-proof__verified-icon {
    width: 14px;
    height: 14px;
    border-radius: 999px;
    background-color: #010d6e;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .stats-proof-{{ section.id }} .stats-proof__verified-icon svg {
    width: 8px;
    height: 8px;
  }

  .stats-proof-{{ section.id }} .stats-proof__verified-label {
    font-family: "PP Mori", sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: {{ section.settings.heading_color }};
    line-height: 1.5;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Desktop */
  @media screen and (min-width: 900px) {
    .stats-proof-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }

    .stats-proof-{{ section.id }} .stats-proof__inner {
      flex-direction: row;
      align-items: stretch;
      gap: 0;
    }

    .stats-proof-{{ section.id }} .stats-proof__image-wrap {
      width: 50%;
      flex-shrink: 0;
      border-radius: 24px;
      aspect-ratio: 1 / 1;
      max-width: 680px;
    }

    .stats-proof-{{ section.id }} .stats-proof__content {
      flex: 1;
      padding: 40px;
      justify-content: space-between;
      gap: 0;
    }

    .stats-proof-{{ section.id }} .stats-proof__tagline {
      font-size: 12px;
    }

    .stats-proof-{{ section.id }} .stats-proof__heading {
      font-size: 32px;
      line-height: 1.3;
    }

    .stats-proof-{{ section.id }} .stats-proof__body {
      font-size: 16px;
    }

    .stats-proof-{{ section.id }} .stats-proof__stats {
      gap: 0;
    }

    .stats-proof-{{ section.id }} .stats-proof__stat-row {
      padding-bottom: 20px;
      margin-bottom: 0;
    }

    .stats-proof-{{ section.id }} .stats-proof__stat-number {
      font-size: 24px;
    }

    .stats-proof-{{ section.id }} .stats-proof__stat-label {
      font-size: 14px;
    }

    .stats-proof-{{ section.id }} .stats-proof__feature-item {
      gap: 12px;
    }

    .stats-proof-{{ section.id }} .stats-proof__feature-icon {
      width: 20px;
      height: 20px;
    }

    .stats-proof-{{ section.id }} .stats-proof__feature-icon svg {
      width: 11px;
      height: 11px;
    }

    .stats-proof-{{ section.id }} .stats-proof__feature-text {
      font-size: 14px;
    }

    .stats-proof-{{ section.id }} .stats-proof__review-card {
      border-radius: 16px;
      padding: 20px;
    }

    .stats-proof-{{ section.id }} .stats-proof__review-image {
      width: 80px;
      height: 80px;
    }

    .stats-proof-{{ section.id }} .stats-proof__review-quote {
      font-size: 14px;
    }

    .stats-proof-{{ section.id }} .stats-proof__verified-icon {
      width: 16px;
      height: 16px;
    }
  }
</style>

{%- liquid
  assign stat_blocks = section.blocks | where: 'type', 'stat_row'
  assign feature_blocks = section.blocks | where: 'type', 'feature_item'
  assign review_blocks = section.blocks | where: 'type', 'review_card'
-%}

<section class="stats-proof-{{ section.id }}">
  <div class="stats-proof__inner">

    {%- if section.settings.image != blank -%}
      <div class="stats-proof__image-wrap">
        {{
          section.settings.image
          | image_url: width: 1360
          | image_tag:
            loading: 'lazy',
            widths: '400, 600, 800, 1000, 1360',
            alt: section.settings.image.alt | escape
        }}
      </div>
    {%- else -%}
      <div class="stats-proof__image-wrap">
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    {%- endif -%}

    <div class="stats-proof__content">

      <!-- Text block -->
      <div class="stats-proof__text-block">
        {%- if section.settings.tagline != blank -%}
          <div class="stats-proof__tagline">
            <span class="stats-proof__tagline-dot"></span>
            {{ section.settings.tagline }}
          </div>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="stats-proof__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.body != blank -%}
          <p class="stats-proof__body">{{ section.settings.body }}</p>
        {%- endif -%}
      </div>

      <!-- Feature items block (optional) -->
      {%- if feature_blocks.size > 0 -%}
        <div class="stats-proof__features">
          {%- for block in feature_blocks -%}
            <div class="stats-proof__feature-item" {{ block.shopify_attributes }}>
              <div class="stats-proof__feature-icon" aria-hidden="true">
                <svg viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M2 5L4 7L8 3" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <span class="stats-proof__feature-text">{{ block.settings.text }}</span>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <!-- Review card block (optional) -->
      {%- for block in review_blocks -%}
        <div class="stats-proof__review-card" {{ block.shopify_attributes }}>
          <div class="stats-proof__review-image">
            {%- if block.settings.product_image != blank -%}
              {{
                block.settings.product_image
                | image_url: width: 160
                | image_tag:
                  loading: 'lazy',
                  alt: block.settings.product_image.alt | escape
              }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="stats-proof__review-content">
            <div class="stats-proof__stars" aria-label="5 out of 5 stars">
              {%- for i in (1..5) -%}
                <svg class="stats-proof__star" viewBox="0 0 12 12" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M6 1L7.5 4.5L11 4.9L8.5 7.2L9.2 11L6 9.2L2.8 11L3.5 7.2L1 4.9L4.5 4.5L6 1Z"/>
                </svg>
              {%- endfor -%}
            </div>
            {%- if block.settings.quote != blank -%}
              <p class="stats-proof__review-quote">{{ block.settings.quote }}</p>
            {%- endif -%}
            <div class="stats-proof__review-attribution">
              {%- if block.settings.reviewer_name != blank -%}
                <span class="stats-proof__review-name">{{ block.settings.reviewer_name }}</span>
              {%- endif -%}
              <span class="stats-proof__review-dot" aria-hidden="true"></span>
              <div class="stats-proof__verified">
                <div class="stats-proof__verified-icon" aria-hidden="true">
                  <svg viewBox="0 0 8 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M1.5 4L3 5.5L6.5 2" stroke="white" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <span class="stats-proof__verified-label">{{ block.settings.verified_label | default: 'Verified Buyer' }}</span>
              </div>
            </div>
          </div>
        </div>
      {%- endfor -%}

      <!-- Stats rows -->
      {%- if stat_blocks.size > 0 -%}
        <div class="stats-proof__stats">
          {%- for block in stat_blocks -%}
            <div class="stats-proof__stat-row" {{ block.shopify_attributes }}>
              <span class="stats-proof__stat-number">{{ block.settings.number }}</span>
              <span class="stats-proof__stat-label">{{ block.settings.label }}</span>
            </div>
          {%- endfor -%}
          {%- if section.settings.footnote != blank -%}
            <p class="stats-proof__footnote">{{ section.settings.footnote }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Stats & Social Proof",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Light Sleepers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Wrap italic words with <em> tags. Example: <em>Protect</em> your night",
      "default": "<em>Protect</em> your night"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "If streetlights, early sun, or a late phone screen pull you out of sleep, your night never feels complete."
    },
    {
      "type": "text",
      "id": "footnote",
      "label": "Footnote",
      "default": "*Based on post purchase customer survey responses."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#fdfbf9"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading & primary text",
      "default": "#182153"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body & secondary text",
      "default": "#182153"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding top — desktop",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom — desktop",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top — mobile",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom — mobile",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "stat_row",
      "name": "Stat row",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "94%"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "said the blackout felt \"complete\""
        }
      ]
    },
    {
      "type": "feature_item",
      "name": "Feature item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Smooth surface for a softer feel"
        }
      ]
    },
    {
      "type": "review_card",
      "name": "Review card",
      "settings": [
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Product image"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Review quote",
          "default": "I did not expect it to make such a difference. It feels weightless, stays in place, and my nights feel calmer."
        },
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Reviewer name",
          "default": "Anna K."
        },
        {
          "type": "text",
          "id": "verified_label",
          "label": "Verified label",
          "default": "Verified Buyer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Stats & Social Proof",
      "blocks": [
        {
          "type": "feature_item",
          "settings": {
            "text": "Smooth surface for a softer feel"
          }
        },
        {
          "type": "feature_item",
          "settings": {
            "text": "Comfortable fit without harsh pressure"
          }
        },
        {
          "type": "review_card",
          "settings": {
            "quote": "I did not expect it to make such a difference. It feels weightless, stays in place, and my nights feel calmer.",
            "reviewer_name": "Anna K.",
            "verified_label": "Verified Buyer"
          }
        },
        {
          "type": "stat_row",
          "settings": {
            "number": "94%",
            "label": "said the blackout felt \"complete\""
          }
        },
        {
          "type": "stat_row",
          "settings": {
            "number": "91%",
            "label": "said it stayed in place all night"
          }
        },
        {
          "type": "stat_row",
          "settings": {
            "number": "89%",
            "label": "said they woke up feeling more rested"
          }
        }
      ]
    }
  ]
}
{% endschema %}
