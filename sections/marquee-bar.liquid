<style>
  #shopify-section-{{ section.id }} {
    padding: 0;
  }

  .marquee-bar-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: 8px;
    padding-bottom: 8px;
    overflow: hidden;
    width: 100%;
  }

  .marquee-bar-{{ section.id }} .marquee__track {
    display: flex;
    flex-direction: row;
    align-items: center;
    width: max-content;
    animation: marquee-scroll-{{ section.id }} {{ section.settings.speed }}s linear infinite;
  }

  .marquee-bar-{{ section.id }}:hover .marquee__track {
    animation-play-state: {% if section.settings.pause_on_hover %}paused{% else %}running{% endif %};
  }

  .marquee-bar-{{ section.id }} .marquee__item {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 24px;
    padding-left: 24px;
    padding-right: 0;
    white-space: nowrap;
  }

  .marquee-bar-{{ section.id }} .marquee__text {
    font-family: "PP Pangaia", serif;
    font-size: 16px;
    font-weight: 500;
    line-height: 1.4;
    color: {{ section.settings.text_color }};
    white-space: nowrap;
    font-style: italic;
  }

  .marquee-bar-{{ section.id }} .marquee__dot {
    flex-shrink: 0;
    display: flex;
  }

  @keyframes marquee-scroll-{{ section.id }} {
    from { transform: translateX(0); }
    to   { transform: translateX(calc(-100% / 6)); }
  }

  @media screen and (min-width: 750px) {
    .marquee-bar-{{ section.id }} .marquee__item {
      gap: 48px;
      padding-left: 48px;
    }

    .marquee-bar-{{ section.id }} .marquee__text {
      font-size: 20px;
    }
  }
</style>

{%- liquid
  assign items = section.blocks | where: 'type', 'item'
-%}

{%- if items.size > 0 -%}
  <div class="marquee-bar-{{ section.id }}" role="marquee" aria-label="Announcements">
    <div class="marquee__track">
      {%- comment %} Repeat 6× so the track always overflows the viewport for seamless loop {%- endcomment %}
      {%- for run in (1..6) -%}
        {%- for block in items -%}
          <div class="marquee__item" {% if run == 1 %}{{ block.shopify_attributes }}{% endif %}>
            <span class="marquee__text">{{ block.settings.text }}</span>
            <span class="marquee__dot" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="4" height="4" viewBox="0 0 4 4" fill="none">
                <circle cx="2" cy="2" r="2" fill="#D9A17D"/>
              </svg>
            </span>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Marquee Bar",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#232e71"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#f8f1e9"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed (seconds for one loop)",
      "min": 10,
      "max": 60,
      "step": 2,
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Marquee item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Same-Day Dispatch"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee Bar",
      "blocks": [
        { "type": "item", "settings": { "text": "Same-Day Dispatch" } },
        { "type": "item", "settings": { "text": "1–2 Business Day Delivery" } },
        { "type": "item", "settings": { "text": "30-Night Money-Back Guarantee" } },
        { "type": "item", "settings": { "text": "Free Shipping over 250 zł" } }
      ]
    }
  ]
}
{% endschema %}
