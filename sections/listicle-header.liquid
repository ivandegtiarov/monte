<style>
  #shopify-section-{{ section.id }} .listicle-nav {
    background: {{ section.settings.background_color | default: '#fdfbf9' }};
    padding-block: 20px;
    display: flex;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .listicle-nav__inner {
    display: flex;
    align-items: center;
    width: 100%;
    max-width: 1360px;
    height: 40px;
    padding-inline: 40px;
  }

  #shopify-section-{{ section.id }} .listicle-nav__left {
    flex: 1;
    display: flex;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .listicle-nav__logo {
    height: 24px;
    width: auto;
    display: block;
  }

  #shopify-section-{{ section.id }} .listicle-nav__right {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  #shopify-section-{{ section.id }} .listicle-nav__button {
    background: #232e71;
    color: #fdfbf9;
    padding-inline: 24px;
    height: 40px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0;
    text-transform: uppercase;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    border: none;
    cursor: pointer;
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .listicle-nav__button:hover {
    opacity: 0.9;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .listicle-nav__inner {
      padding-inline: 20px;
    }

    #shopify-section-{{ section.id }} .listicle-nav__button {
      font-size: 12px;
      padding-inline: 16px;
      height: 36px;
    }
  }
</style>

<div class="listicle-nav">
  <div class="listicle-nav__inner">
    <div class="listicle-nav__left">
      {%- if section.settings.logo != blank -%}
        {%- assign logo_alt = section.settings.logo.alt | default: shop.name | escape -%}
        {{-
          section.settings.logo
          | image_url: width: 270
          | image_tag:
            class: 'listicle-nav__logo',
            alt: logo_alt,
            loading: 'eager'
        -}}
      {%- endif -%}
    </div>

    <div class="listicle-nav__right">
      {%- if section.settings.button_label != blank -%}
        {%- if section.settings.button_url != blank -%}
          <a href="{{ section.settings.button_url }}" class="listicle-nav__button">
            {{- section.settings.button_label | escape -}}
          </a>
        {%- else -%}
          <button type="button" class="listicle-nav__button">
            {{- section.settings.button_label | escape -}}
          </button>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Listicle – Header",
  "class": "shopify-section--listicle-header",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Sprawdź dostępność"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#fdfbf9"
    }
  ],
  "presets": [
    {
      "name": "Listicle – Header"
    }
  ]
}
{% endschema %}
