{%- assign s = section.settings -%}

{% style %}
  #lv3-items-{{ section.id }} {
    background-color: {{ s.background_color }};
    padding-top: {{ s.padding_top_mobile }}px;
    padding-bottom: {{ s.padding_bottom_mobile }}px;
    padding-left: 20px;
    padding-right: 20px;
  }

  #lv3-items-{{ section.id }} .lv3-items__inner {
    max-width: {{ s.content_max_width }}px;
    margin-left: auto;
    margin-right: auto;
    display: flex;
    flex-direction: column;
    gap: {{ s.item_gap_mobile }}px;
  }

  /* Item — mobile: vertical stack (header → image → body) */
  #lv3-items-{{ section.id }} .lv3-item {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  #lv3-items-{{ section.id }} .lv3-item__header {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  #lv3-items-{{ section.id }} .lv3-item__label {
    font-family: "PP Mori", sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: {{ s.label_color }};
    line-height: 1.5;
  }

  #lv3-items-{{ section.id }} .lv3-item__title {
    font-family: "PP Pangaia", serif;
    font-size: {{ s.heading_size_mobile }}px;
    font-weight: 500;
    color: {{ s.heading_color }};
    line-height: 1.3;
  }

  #lv3-items-{{ section.id }} .lv3-item__title p {
    margin: 0;
  }

  /* Image block */
  #lv3-items-{{ section.id }} .lv3-item__media {
    position: relative;
    width: 100%;
    height: {{ s.image_height_mobile }}px;
    border-radius: {{ s.image_border_radius }}px;
    overflow: hidden;
    flex-shrink: 0;
    background-color: {{ s.caption_bg_color }};
  }

  #lv3-items-{{ section.id }} .lv3-item__image,
  #lv3-items-{{ section.id }} .lv3-item__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #lv3-items-{{ section.id }} .lv3-item__caption {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    background-color: {{ s.caption_bg_color }};
    color: {{ s.caption_text_color }};
    padding: 10px 20px;
    font-family: "PP Pangaia", serif;
    font-size: 20px;
    font-weight: 500;
    line-height: 1.4;
    text-align: center;
    box-sizing: border-box;
  }

  /* Body text */
  #lv3-items-{{ section.id }} .lv3-item__body {
    font-family: "PP Mori", sans-serif;
    font-size: {{ s.body_size_mobile }}px;
    font-weight: 300;
    color: {{ s.text_color }};
    opacity: {{ s.text_opacity | times: 0.01 }};
    line-height: 1.5;
  }

  #lv3-items-{{ section.id }} .lv3-item__body p {
    margin: 0 0 1em;
  }

  #lv3-items-{{ section.id }} .lv3-item__body p:last-child {
    margin-bottom: 0;
  }

  #lv3-items-{{ section.id }} .lv3-item__body strong {
    font-family: "PP Mori", sans-serif;
    font-weight: 800;
  }

  /* Desktop: CSS Grid — text column left, image spans both rows right */
  @media (min-width: 768px) {
    #lv3-items-{{ section.id }} {
      padding-top: {{ s.padding_top_desktop }}px;
      padding-bottom: {{ s.padding_bottom_desktop }}px;
    }

    #lv3-items-{{ section.id }} .lv3-items__inner {
      gap: {{ s.item_gap_desktop }}px;
    }

    #lv3-items-{{ section.id }} .lv3-item {
      display: grid;
      grid-template-columns: {{ s.text_col_width }}px {{ s.image_width_desktop }}px;
      grid-template-rows: auto 1fr;
      column-gap: {{ s.col_gap_desktop }}px;
      row-gap: 16px;
      align-items: start;
    }

    #lv3-items-{{ section.id }} .lv3-item__header {
      grid-column: 1;
      grid-row: 1;
    }

    #lv3-items-{{ section.id }} .lv3-item__media {
      grid-column: 2;
      grid-row: 1 / 3;
      height: {{ s.image_height_desktop }}px;
      width: {{ s.image_width_desktop }}px;
    }

    #lv3-items-{{ section.id }} .lv3-item__body {
      grid-column: 1;
      grid-row: 2;
      font-size: {{ s.body_size_desktop }}px;
    }

    #lv3-items-{{ section.id }} .lv3-item__title {
      font-size: {{ s.heading_size_desktop }}px;
    }

    /* Image-left variant */
    #lv3-items-{{ section.id }} .lv3-item--image-left {
      grid-template-columns: {{ s.image_width_desktop }}px {{ s.text_col_width }}px;
    }

    #lv3-items-{{ section.id }} .lv3-item--image-left .lv3-item__header {
      grid-column: 2;
    }

    #lv3-items-{{ section.id }} .lv3-item--image-left .lv3-item__media {
      grid-column: 1;
    }

    #lv3-items-{{ section.id }} .lv3-item--image-left .lv3-item__body {
      grid-column: 2;
    }
  }
{% endstyle %}

<section
  id="lv3-items-{{ section.id }}"
  {% if s.section_id != blank %}data-anchor="{{ s.section_id | handleize }}"{% endif %}
>
  <div class="lv3-items__inner">
    {%- for block in section.blocks -%}
      {%- assign b = block.settings -%}
      <div
        class="lv3-item{% if b.image_position == 'left' %} lv3-item--image-left{% endif %}"
        {{ block.shopify_attributes }}
      >

        <div class="lv3-item__header">
          {%- if b.label != blank -%}
            <span class="lv3-item__label">{{ b.label | escape }}</span>
          {%- endif -%}
          {%- if b.title != blank -%}
            <div class="lv3-item__title">{{ b.title }}</div>
          {%- endif -%}
        </div>

        <div class="lv3-item__media">
          {%- if b.video != blank -%}
            <video
              class="lv3-item__video"
              autoplay
              loop
              muted
              playsinline
              preload="metadata"
            >
              {%- for source in b.video.sources -%}
                <source src="{{ source.url }}" type="{{ source.mime_type }}">
              {%- endfor -%}
            </video>
          {%- elsif b.image != blank -%}
            {{
              b.image
              | image_url: width: 900
              | image_tag:
                class: 'lv3-item__image',
                alt: b.image_alt,
                loading: 'lazy',
                widths: '400, 600, 900'
            }}
          {%- endif -%}
          {%- if b.image_caption != blank -%}
            <div class="lv3-item__caption" aria-hidden="true">{{ b.image_caption | escape }}</div>
          {%- endif -%}
        </div>

        {%- if b.body != blank -%}
          <div class="lv3-item__body">{{ b.body }}</div>
        {%- endif -%}

      </div>
    {%- endfor -%}
  </div>
</section>

