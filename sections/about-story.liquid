<style>
  #shopify-section-{{ section.id }} {
    --padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .about-story {
    background: #ffffff;
    padding-block-start: var(--padding-top);
    padding-block-end: var(--padding-bottom);
    padding-inline: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .about-story__inner {
    display: flex;
    align-items: center;
    width: 100%;
    max-width: 1360px;
  }

  /* Image */
  #shopify-section-{{ section.id }} .about-story__image-col {
    flex-shrink: 0;
    width: 680px;
    height: 680px;
    border-radius: 24px;
    overflow: hidden;
    position: relative;
  }

  #shopify-section-{{ section.id }} .about-story__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .about-story__image-placeholder {
    width: 100%;
    height: 100%;
    background: #e8e0d8;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Content */
  #shopify-section-{{ section.id }} .about-story__content-col {
    flex: 1 0 0;
    min-width: 0;
    padding: 40px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-self: stretch;
    justify-content: center;
  }

  /* Tagline */
  #shopify-section-{{ section.id }} .about-story__tagline {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  #shopify-section-{{ section.id }} .about-story__tagline-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(24, 33, 83, 0.75);
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .about-story__tagline-text {
    font-family: "PP Neue Montreal Mono", monospace;
    font-size: 12px;
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: rgba(24, 33, 83, 0.75);
    margin: 0;
  }

  /* Title + body */
  #shopify-section-{{ section.id }} .about-story__text {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  #shopify-section-{{ section.id }} .about-story__title {
    font-family: var(--heading-font-family);
    font-size: 32px;
    font-weight: 500;
    line-height: 1.3;
    color: #182153;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .about-story__body {
    font-family: var(--text-font-family);
    font-size: 16px;
    line-height: 1.5;
    color: rgba(24, 33, 83, 0.75);
  }

  #shopify-section-{{ section.id }} .about-story__body p {
    margin-block-end: 0;
  }

  #shopify-section-{{ section.id }} .about-story__body p + p {
    margin-block-start: 1em;
  }

  #shopify-section-{{ section.id }} .about-story__inner--image-end {
    flex-direction: row-reverse;
  }

  /* Mobile */
  @media screen and (max-width: 899px) {
    #shopify-section-{{ section.id }} .about-story {
      padding-inline: 20px;
      padding-block-start: 32px;
      padding-block-end: 16px;
    }

    #shopify-section-{{ section.id }} .about-story__inner {
      flex-direction: column;
      gap: 24px;
    }

    #shopify-section-{{ section.id }} .about-story__image-col {
      width: 100%;
      height: auto;
      aspect-ratio: 1;
    }

    #shopify-section-{{ section.id }} .about-story__content-col {
      padding: 0;
    }

    #shopify-section-{{ section.id }} .about-story__title {
      font-size: 24px;
    }
  }
</style>

<div class="about-story">
  <div class="about-story__inner{% if section.settings.image_position == 'end' %} about-story__inner--image-end{% endif %}">

    <div class="about-story__image-col">
      {%- if section.settings.image != blank -%}
        {{-
          section.settings.image
          | image_url: width: section.settings.image.width
          | image_tag:
            class: 'about-story__image',
            loading: 'lazy',
            sizes: '(max-width: 899px) 100vw, 680px',
            widths: '400,600,800,1000,1360',
            alt: section.settings.image.alt | escape
        -}}
      {%- else -%}
        <div class="about-story__image-placeholder">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {%- endif -%}
    </div>

    <div class="about-story__content-col">

      {%- if section.settings.tagline != blank -%}
        <div class="about-story__tagline">
          <span class="about-story__tagline-dot" aria-hidden="true"></span>
          <p class="about-story__tagline-text">{{ section.settings.tagline | escape }}</p>
        </div>
      {%- endif -%}

      <div class="about-story__text">
        {%- if section.settings.title != blank -%}
          <h2 class="about-story__title">{{ section.settings.title | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.content != blank -%}
          <div class="about-story__body">{{ section.settings.content }}</div>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "About – Story",
  "class": "shopify-section--about-story",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "start", "label": "Left" },
        { "value": "end", "label": "Right" }
      ],
      "default": "start"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "JAK TO SIĘ ZACZĘŁO"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Mały rytuał, który zmienia całą noc"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>Wiesz, jak to jest, kiedy dzień w końcu się kończy.</p><p>Kiedy zamykasz ostatnią aplikację, odkładasz telefon i masz chwilę tylko dla siebie. Ta chwila jest rzadka. I zasługuje na coś wyjątkowego.</p><p>Monté powstało z przekonania, że wieczorna rutyna może być czymś więcej niż obowiązkiem. Małym, codziennym aktem troski o siebie, który zamienia zwykłe kładzenie się do łóżka w coś, na co czekasz.</p><p>Zaczęliśmy od jedwabiu morwowego, bo wierzyliśmy, że materiał, który dotyka twojej twarzy przez całą noc, powinien być po prostu najlepszy z możliwych.</p><p>I tak powstała maska, która nie tylko pomaga spać. Sprawia, że chcesz iść spać.</p>"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "About – Story"
    }
  ]
}
{% endschema %}
