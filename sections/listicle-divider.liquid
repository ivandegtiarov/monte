<style>
  #shopify-section-{{ section.id }} .lc-divider {
    width: 100%;
    overflow: hidden;
    display: block;
    line-height: 0;
    background: {{ section.settings.background_color | default: '#f8f1e9' }};
  }

  /* ── Custom image mode ── */
  #shopify-section-{{ section.id }} .lc-divider__image {
    width: 100%;
    display: block;
  }

  #shopify-section-{{ section.id }} .lc-divider__image img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── CSS arch fallback ── */
  #shopify-section-{{ section.id }} .lc-divider__arch-wrap {
    width: 100%;
    /* aspect-ratio controls the height of the arch */
    padding-bottom: {{ section.settings.arch_height | default: 20 }}%;
    position: relative;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .lc-divider__arch {
    position: absolute;
    bottom: 0;
    left: -5%;
    width: 110%;
    height: 200%;
    background: {{ section.settings.arch_color | default: '#232e71' }};
    border-radius: 50% 50% 0 0 / 100% 100% 0 0;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .lc-divider__arch-wrap {
      padding-bottom: {{ section.settings.arch_height_mobile | default: 28 }}%;
    }
  }
</style>

<div class="lc-divider">
  {%- if section.settings.illustration != blank -%}
    <div class="lc-divider__image">
      {{-
        section.settings.illustration
        | image_url: width: 2400
        | image_tag:
          loading: 'lazy',
          sizes: '100vw',
          widths: '750,1100,1500,1800,2400',
          alt: ''
      -}}
    </div>
  {%- else -%}
    <div class="lc-divider__arch-wrap">
      <div class="lc-divider__arch"></div>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Listicle – Divider",
  "class": "shopify-section--listicle-divider",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Illustration"
    },
    {
      "type": "image_picker",
      "id": "illustration",
      "label": "Custom illustration",
      "info": "Upload a custom SVG/PNG to replace the default arch. Leave empty to use the CSS arch."
    },
    {
      "type": "header",
      "content": "CSS arch (fallback)"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f8f1e9"
    },
    {
      "type": "color",
      "id": "arch_color",
      "label": "Arch color",
      "default": "#232e71"
    },
    {
      "type": "range",
      "id": "arch_height",
      "label": "Arch height — Desktop",
      "info": "As % of section width",
      "min": 5,
      "max": 40,
      "step": 1,
      "unit": "%",
      "default": 20
    },
    {
      "type": "range",
      "id": "arch_height_mobile",
      "label": "Arch height — Mobile",
      "info": "As % of section width",
      "min": 5,
      "max": 50,
      "step": 1,
      "unit": "%",
      "default": 28
    }
  ],
  "presets": [
    {
      "name": "Listicle – Divider"
    }
  ]
}
{% endschema %}
