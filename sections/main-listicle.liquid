{%- render 'section-spacing-collapsing' -%}

<style>
  #shopify-section-{{ section.id }} {
    --listicle-max-width: {{ section.settings.content_width }};
    --listicle-number-color: {{ section.settings.number_color.rgb | default: 'var(--text-color)' }};
    --listicle-number-opacity: 0.12;
    --listicle-divider-color: {{ section.settings.text_color.rgb | default: 'var(--text-color)' }};
  }

  #shopify-section-{{ section.id }} .listicle {
    max-width: var(--listicle-max-width);
    margin-inline: auto;
  }

  #shopify-section-{{ section.id }} .listicle__header {
    max-width: 800px;
    margin-inline: auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .listicle__title-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .listicle__title-group .prose {
    max-width: 600px;
    width: 100%;
  }

  /* Social proof */
  #shopify-section-{{ section.id }} .listicle__social-proof {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  #shopify-section-{{ section.id }} .listicle__avatars {
    display: flex;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .listicle__avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid #fff;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .listicle__avatar:not(:first-child) {
    margin-inline-start: -6px;
  }

  #shopify-section-{{ section.id }} .listicle__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .listicle__social-text {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.5;
    white-space: nowrap;
  }

  /* Header text */
  #shopify-section-{{ section.id }} .listicle__title {
    max-width: 760px;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .listicle__title em {
    font-style: italic;
  }

  /* Hero image */
  #shopify-section-{{ section.id }} .listicle__hero-image {
    width: 600px;
    max-width: 100%;
    height: 320px;
    border-radius: 32px;
    overflow: hidden;
    flex-shrink: 0;
    margin-inline: auto;
  }

  #shopify-section-{{ section.id }} .listicle__hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Intro wrapper (header + hero + body) */
  #shopify-section-{{ section.id }} .listicle__intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
    width: 100%;
    margin-block-end: var(--spacing-12);
  }

  /* Body content below hero */
  #shopify-section-{{ section.id }} .listicle__body {
    max-width: 600px;
    width: 100%;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 20px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .listicle__body-conclusion {
    font-weight: 600;
  }

  /* Items */
  #shopify-section-{{ section.id }} .listicle__items {
    display: grid;
    gap: var(--spacing-16);
  }

  #shopify-section-{{ section.id }} .listicle__item {
    display: grid;
    grid-template-areas: "number" "media" "content";
    gap: var(--spacing-6);
    padding-block-end: var(--spacing-16);
    border-bottom: 1px solid rgba(var(--listicle-divider-color) / 0.15);
  }

  #shopify-section-{{ section.id }} .listicle__item:last-child {
    border-bottom: none;
    padding-block-end: 0;
  }

  #shopify-section-{{ section.id }} .listicle__number {
    font-size: clamp(4rem, 10vw, 7rem);
    font-weight: 700;
    line-height: 1;
    color: rgba(var(--listicle-number-color) / var(--listicle-number-opacity));
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }

  #shopify-section-{{ section.id }} .listicle__media {
    grid-area: media;
    border-radius: var(--rounded-md, 8px);
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  #shopify-section-{{ section.id }} .listicle__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .listicle__content {
    grid-area: content;
  }

  #shopify-section-{{ section.id }} .listicle__item-title {
    margin-block-end: var(--spacing-4);
  }

  @media screen and (min-width: 900px) {
    #shopify-section-{{ section.id }} .listicle__items {
      gap: 0;
    }

    #shopify-section-{{ section.id }} .listicle__item {
      grid-template-areas: "number media content" ". media content";
      grid-template-columns: 120px minmax(0, 1fr) minmax(0, 1fr);
      grid-template-rows: auto 1fr;
      gap: var(--spacing-4) var(--spacing-10);
      padding-block: var(--spacing-14);
    }

    #shopify-section-{{ section.id }} .listicle__item--image-right {
      grid-template-areas: "number content media" ". content media";
      grid-template-columns: 120px minmax(0, 1fr) minmax(0, 1fr);
    }

    #shopify-section-{{ section.id }} .listicle__media {
      aspect-ratio: 4 / 3;
    }
  }
</style>

<div {% render 'section-properties' %}>
  <div class="listicle container">

    {%- liquid
      assign has_header = false
      if section.settings.tagline != blank or section.settings.title != blank or section.settings.intro != blank
        assign has_header = true
      endif
      if section.settings.social_proof_text != blank or section.settings.hero_image != blank or section.settings.body_content != blank or section.settings.body_conclusion != blank
        assign has_header = true
      endif
      if section.settings.social_proof_image_1 != blank or section.settings.social_proof_image_2 != blank or section.settings.social_proof_image_3 != blank
        assign has_header = true
      endif
    -%}

    {%- if has_header -%}
      <div class="listicle__intro">
        <div class="listicle__header">

          {%- if section.settings.social_proof_text != blank
            or section.settings.social_proof_image_1 != blank
            or section.settings.social_proof_image_2 != blank
            or section.settings.social_proof_image_3 != blank -%}
            <div class="listicle__social-proof">
              {%- if section.settings.social_proof_image_1 != blank
                or section.settings.social_proof_image_2 != blank
                or section.settings.social_proof_image_3 != blank -%}
                <div class="listicle__avatars">
                  {%- if section.settings.social_proof_image_1 != blank -%}
                    <div class="listicle__avatar">
                      {{- section.settings.social_proof_image_1 | image_url: width: 64 | image_tag: loading: 'lazy', alt: '' -}}
                    </div>
                  {%- endif -%}
                  {%- if section.settings.social_proof_image_2 != blank -%}
                    <div class="listicle__avatar">
                      {{- section.settings.social_proof_image_2 | image_url: width: 64 | image_tag: loading: 'lazy', alt: '' -}}
                    </div>
                  {%- endif -%}
                  {%- if section.settings.social_proof_image_3 != blank -%}
                    <div class="listicle__avatar">
                      {{- section.settings.social_proof_image_3 | image_url: width: 64 | image_tag: loading: 'lazy', alt: '' -}}
                    </div>
                  {%- endif -%}
                </div>
              {%- endif -%}

              {%- if section.settings.social_proof_text != blank -%}
                <p class="listicle__social-text">{{ section.settings.social_proof_text | escape }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- if section.settings.tagline != blank or section.settings.title != blank or section.settings.intro != blank -%}
            <div class="listicle__title-group">
              {%- if section.settings.tagline != blank -%}
                <p class="subheading">{{ section.settings.tagline | escape }}</p>
              {%- endif -%}

              {%- if section.settings.title != blank -%}
                <h1 class="listicle__title h2">{{ section.settings.title | remove: '<p>' | remove: '</p>' }}</h1>
              {%- endif -%}

              {%- if section.settings.intro != blank -%}
                <div class="prose text-subdued">{{ section.settings.intro }}</div>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

        {%- if section.settings.hero_image != blank -%}
          <div class="listicle__hero-image">
            {{-
              section.settings.hero_image
              | image_url: width: section.settings.hero_image.width
              | image_tag:
                loading: 'lazy',
                sizes: '(max-width: 699px) 100vw, 600px',
                widths: '400,600,800,1000,1200',
                alt: section.settings.hero_image.alt | escape
            -}}
          </div>
        {%- endif -%}

        {%- if section.settings.body_content != blank or section.settings.body_conclusion != blank -%}
          <div class="listicle__body">
            {%- if section.settings.body_content != blank -%}
              <div class="prose text-subdued">{{ section.settings.body_content }}</div>
            {%- endif -%}
            {%- if section.settings.body_conclusion != blank -%}
              <div class="listicle__body-conclusion prose">{{ section.settings.body_conclusion }}</div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="listicle__items">
        {%- for block in section.blocks -%}
          {%- assign item_number = forloop.index -%}
          {%- assign number_label = item_number | prepend: '0' | slice: -2, 2 -%}
          {%- assign image_side = block.settings.image_position -%}

          <div
            class="listicle__item{% if image_side == 'end' %} listicle__item--image-right{% endif %}"
            {{ block.shopify_attributes }}
          >
            <div class="listicle__number" aria-hidden="true">{{ number_label }}</div>

            {%- if block.settings.image != blank -%}
              <div class="listicle__media">
                {{-
                  block.settings.image
                  | image_url: width: block.settings.image.width
                  | image_tag:
                    loading: 'lazy',
                    sizes: '(max-width: 899px) 100vw, 50vw',
                    widths: '400,600,800,1000,1200,1400',
                    alt: block.settings.image.alt | escape
                -}}
              </div>
            {%- endif -%}

            <div class="listicle__content v-stack gap-4">
              {%- if block.settings.title != blank -%}
                <h2 class="listicle__item-title h4">{{ block.settings.title | escape }}</h2>
              {%- endif -%}

              {%- if block.settings.content != blank -%}
                <div class="prose">{{ block.settings.content }}</div>
              {%- endif -%}

              {%- if block.settings.button_label != blank and block.settings.button_url != blank -%}
                {%- render 'button',
                  content: block.settings.button_label,
                  href: block.settings.button_url,
                  size: 'base',
                  style: 'outline'
                -%}
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Listicle",
  "class": "shopify-section--main-listicle",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Social proof"
    },
    {
      "type": "image_picker",
      "id": "social_proof_image_1",
      "label": "Avatar 1"
    },
    {
      "type": "image_picker",
      "id": "social_proof_image_2",
      "label": "Avatar 2"
    },
    {
      "type": "image_picker",
      "id": "social_proof_image_3",
      "label": "Avatar 3"
    },
    {
      "type": "text",
      "id": "social_proof_text",
      "label": "Social proof text"
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "info": "Use italic formatting for styled words"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro text"
    },
    {
      "type": "header",
      "content": "Hero image"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "header",
      "content": "Body text"
    },
    {
      "type": "richtext",
      "id": "body_content",
      "label": "Body content",
      "info": "Displayed below the hero image"
    },
    {
      "type": "richtext",
      "id": "body_conclusion",
      "label": "Body conclusion",
      "info": "Displayed below body content in semibold"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "Content width",
      "options": [
        { "value": "900px", "label": "Narrow" },
        { "value": "1100px", "label": "Medium" },
        { "value": "1300px", "label": "Wide" }
      ],
      "default": "1100px"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text"
    },
    {
      "type": "color",
      "id": "number_color",
      "label": "Number color",
      "info": "Large decorative numbers"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Listicle item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Item title"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Describe this item. Add enough detail to be useful and engaging for the reader.</p>"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "image_position",
          "label": "Image position (desktop)",
          "options": [
            { "value": "start", "label": "Left" },
            { "value": "end", "label": "Right" }
          ],
          "default": "start"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Listicle",
      "category": "Content",
      "settings": {
        "tagline": "EDITORIAL",
        "title": "<p>Page title</p>"
      },
      "blocks": [
        {
          "type": "item",
          "settings": {
            "title": "First item",
            "image_position": "start"
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Second item",
            "image_position": "end"
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Third item",
            "image_position": "start"
          }
