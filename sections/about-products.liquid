<style>
  #shopify-section-{{ section.id }} {
    --padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .about-products {
    background: linear-gradient(to bottom, #ffffff, #fdfbf9);
    padding: var(--padding-top) 40px var(--padding-bottom);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
  }

  /* Header */
  #shopify-section-{{ section.id }} .about-products__header {
    max-width: 600px;
    width: 100%;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  #shopify-section-{{ section.id }} .about-products__title {
    font-family: var(--heading-font-family);
    font-size: 32px;
    font-weight: 500;
    line-height: 1.3;
    color: #182153;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .about-products__subtitle {
    font-family: var(--text-font-family);
    font-size: 16px;
    line-height: 1.5;
    color: rgba(24, 33, 83, 0.75);
    margin: 0;
  }

  /* Grid */
  #shopify-section-{{ section.id }} .about-products__grid {
    display: flex;
    gap: 8px;
    align-items: flex-start;
    width: 100%;
  }

  /* Card */
  #shopify-section-{{ section.id }} .about-products__card {
    flex: 1 0 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  /* Image wrapper */
  #shopify-section-{{ section.id }} .about-products__card-media {
    position: relative;
    height: 420px;
    background: #fbf7f3;
    border-radius: 16px;
    overflow: hidden;
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .about-products__card-img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.45s ease;
    transform-origin: center;
  }

  #shopify-section-{{ section.id }} .about-products__card:hover .about-products__card-img {
    transform: scale(1.1);
  }

  /* Badge */
  #shopify-section-{{ section.id }} .about-products__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: #2f6b57;
    color: #d9e8e1;
    font-family: var(--text-font-family);
    font-size: 10px;
    font-weight: 600;
    line-height: 1.5;
    text-transform: uppercase;
    white-space: nowrap;
    height: 24px;
    padding-inline: 12px;
    border-radius: 999px;
    display: flex;
    align-items: center;
    z-index: 1;
  }

  /* Plus button */
  #shopify-section-{{ section.id }} .about-products__add {
    position: absolute;
    bottom: 12px;
    right: 12px;
    width: 20px;
    height: 20px;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  #shopify-section-{{ section.id }} .about-products__add:hover {
    transform: scale(1.15);
    opacity: 0.8;
  }

  #shopify-section-{{ section.id }} .about-products__add svg {
    width: 20px;
    height: 20px;
    display: block;
  }

  /* Text area */
  #shopify-section-{{ section.id }} .about-products__card-info {
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  #shopify-section-{{ section.id }} .about-products__card-row {
    display: flex;
    gap: 12px;
    align-items: center;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .about-products__card-name {
    flex: 1 0 0;
    min-width: 0;
    font-family: var(--text-font-family);
    font-size: 12px;
    font-weight: 600;
    line-height: 1.5;
    color: #182153;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .about-products__prices {
    display: flex;
    gap: 8px;
    align-items: center;
    white-space: nowrap;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .about-products__price-old {
    font-family: var(--text-font-family);
    font-size: 10px;
    font-weight: 600;
    line-height: 1.5;
    color: #182153;
    opacity: 0.5;
    text-decoration: line-through;
    text-decoration-skip-ink: none;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .about-products__price {
    font-family: var(--text-font-family);
    font-size: 12px;
    font-weight: 600;
    line-height: 1.5;
    color: #182153;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .about-products__card-tagline {
    font-family: "PP Neue Montreal Mono", monospace;
    font-size: 10px;
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: rgba(24, 33, 83, 0.75);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Mobile */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .about-products {
      padding-inline: 20px;
      gap: 28px;
    }

    #shopify-section-{{ section.id }} .about-products__grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    #shopify-section-{{ section.id }} .about-products__card-media {
      height: 200px;
    }

    #shopify-section-{{ section.id }} .about-products__title {
      font-size: 24px;
    }

    #shopify-section-{{ section.id }} .about-products__card-tagline {
      display: none;
    }
  }
</style>

<div class="about-products">

  {%- if section.settings.title != blank or section.settings.subtitle != blank -%}
    <div class="about-products__header">
      {%- if section.settings.title != blank -%}
        <h2 class="about-products__title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="about-products__subtitle">{{ section.settings.subtitle | escape }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="about-products__grid">
      {%- for block in section.blocks -%}
        {%- assign product = block.settings.product -%}
        {%- if product != blank -%}
          {%- assign variant = product.selected_or_first_available_variant -%}

          {%- comment -%} Calculate discount percentage {%- endcomment -%}
          {%- assign show_badge = false -%}
          {%- if product.compare_at_price > product.price -%}
            {%- assign show_badge = true -%}
            {%- assign savings = product.compare_at_price | minus: product.price -%}
            {%- assign savings_pct = savings | times: 100.0 | divided_by: product.compare_at_price | round -%}
          {%- endif -%}

          <a
            href="{{ product.url }}"
            class="about-products__card"
            {{ block.shopify_attributes }}
          >
            <div class="about-products__card-media">

              {%- if product.featured_image != blank -%}
                {{-
                  product.featured_image
                  | image_url: width: 800
                  | image_tag:
                    class: 'about-products__card-img',
                    loading: 'lazy',
                    sizes: '(max-width: 749px) 50vw, 25vw',
                    widths: '300,400,600,800',
                    alt: product.featured_image.alt | escape
                -}}
              {%- endif -%}

              {%- if show_badge -%}
                <span class="about-products__badge">oszczędzasz {{ savings_pct }}%</span>
              {%- endif -%}

              <button
                type="button"
                class="about-products__add"
                data-variant-id="{{ variant.id }}"
                data-product-id="{{ product.id }}"
                aria-label="{{ 'general.accessibility.add_to_cart' | t | default: 'Dodaj do koszyka' }}: {{ product.title | escape }}"
              >
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M10 3.5V16.5M3.5 10H16.5" stroke="#182153" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </button>

            </div>

            <div class="about-products__card-info">
              <div class="about-products__card-row">
                <p class="about-products__card-name">
                  {%- if block.settings.custom_title != blank -%}
                    {{- block.settings.custom_title | escape -}}
                  {%- else -%}
                    {{- product.title | escape -}}
                  {%- endif -%}
                </p>
                <div class="about-products__prices">
                  {%- if product.compare_at_price > product.price -%}
                    <s class="about-products__price-old">{{ product.compare_at_price | money }}</s>
                  {%- endif -%}
                  <span class="about-products__price">{{ product.price | money }}</span>
                </div>
              </div>
              {%- if block.settings.tagline != blank -%}
                <p class="about-products__card-tagline">{{ block.settings.tagline | escape }}</p>
              {%- endif -%}
            </div>
          </a>

        {%- else -%}
          <div class="about-products__card" {{ block.shopify_attributes }}>
            <div class="about-products__card-media">
              {{ 'product-1' | placeholder_svg_tag: 'about-products__card-img' }}
            </div>
            <div class="about-products__card-info">
              <div class="about-products__card-row">
                <p class="about-products__card-name">{{ 'onboarding.product.title' | t | default: 'Produkt' }}</p>
              </div>
              {%- if block.settings.tagline != blank -%}
                <p class="about-products__card-tagline">{{ block.settings.tagline | escape }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

</div>

<script>
  (function () {
    var sectionEl = document.getElementById('shopify-section-{{ section.id }}');
    if (!sectionEl) return;

    var SVG_PLUS  = '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M10 3.5V16.5M3.5 10H16.5" stroke="#182153" stroke-width="1.5" stroke-linecap="round"/></svg>';
    var SVG_CHECK = '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M4 10.5L8 14.5L16 6.5" stroke="#2f6b57" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';

    sectionEl.querySelectorAll('.about-products__add').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();

        var variantId = btn.dataset.variantId;
        if (!variantId || btn.disabled) return;

        btn.disabled = true;
        btn.style.opacity = '0.4';

        /* Collect sections for cart drawer (matches maison-bundle pattern) */
        var sectionsToBundle = ['variant-added'];
        document.documentElement.dispatchEvent(new CustomEvent('cart:prepare-bundled-sections', {
          bubbles: true,
          detail: { sections: sectionsToBundle }
        }));

        /* Build FormData with _bundle property (matches maison-bundle) */
        var formData = new FormData();
        formData.append('items[0][id]', variantId);
        formData.append('items[0][quantity]', '1');
        formData.append('items[0][properties][_bundle]', 'true');
        formData.set('sections', sectionsToBundle.join(','));
        formData.set('sections_url', window.location.pathname);

        fetch(window.Shopify.routes.root + 'cart/add.js', {
          method: 'POST',
          headers: { 'X-Requested-With': 'XMLHttpRequest' },
          body: formData
        })
          .then(function (res) { return res.json().then(function (data) { return { ok: res.ok, data: data }; }); })
          .then(function (result) {
            if (!result.ok) {
              document.dispatchEvent(new CustomEvent('cart:refresh'));
              return;
            }

            btn.innerHTML = SVG_CHECK;
            btn.style.opacity = '1';

            /* Fetch updated cart and dispatch events to open cart drawer */
            return fetch(window.Shopify.routes.root + 'cart.js', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
              .then(function (r) { return r.json(); })
              .then(function (cartContent) {
                cartContent['sections'] = result.data['sections'];

                btn.dispatchEvent(new CustomEvent('variant:add', {
                  bubbles: true,
                  detail: {
                    items: result.data.hasOwnProperty('items') ? result.data['items'] : [result.data],
                    cart: cartContent
                  }
                }));

                document.documentElement.dispatchEvent(new CustomEvent('cart:change', {
                  bubbles: true,
                  detail: { baseEvent: 'variant:add', cart: cartContent }
                }));

                          });
          })
          .catch(function (err) {
            console.error('About Products ATC error:', err);
            btn.style.opacity = '1';
          })
          .finally(function () {
            setTimeout(function () {
              btn.innerHTML = SVG_PLUS;
              btn.disabled = false;
            }, 2000);
          });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "About – Products",
  "class": "shopify-section--about-products",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Twoja pierwsza noc z Monté"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Wybierz kolor i przekonaj się, jak wiele może zmienić jedna dobra noc."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom name",
          "info": "Overrides the product title. Leave blank to use the product name."
        },
        {
          "type": "text",
          "id": "tagline",
          "label": "Tagline",
          "default": "100% Jedwab morwowy 22 momme"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "About – Products",
      "blocks": [
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}
