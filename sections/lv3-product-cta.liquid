      "blocks": [
        { "type": "feature", "settings": { "text": "Pełny blackout, bez prześwitów" } },
        { "type": "feature", "settings": { "text": "100% jedwab, nie wchłania kosmetyków" } },
        { "type": "feature", "settings": { "text": "Miękki regulowany rzep zamiast gumki" } },
