        { "type": "trust", "settings": { "icon_type": "return", "text": "30-nocna gwarancja zwrotu pieniędzy" } },
        { "type": "trust", "settings": { "icon_type": "truck", "text": "Dostawa kurierem InPost w 1–2 dni robocze" } }
      ]
    }
  ]
}
{% endschema %}
