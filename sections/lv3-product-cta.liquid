        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Trust badge text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LV3 Product CTA",
      "settings": {
        "title": "<p>Jutro rano możesz obudzić się inaczej</p>",
        "subtitle": "<p>Jedwabna maska Monté. Pełny blackout, gładki jedwab, regulowany rzep. Wszystko, o czym właśnie przeczytałaś, w jednej masce.</p>",
