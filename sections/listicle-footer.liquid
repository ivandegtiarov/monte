<style>
  #shopify-section-{{ section.id }} .listicle-footer {
    background: linear-gradient(to bottom, #232e71, #141a3f);
    padding-block: 40px;
    padding-inline: 40px;
  }

  #shopify-section-{{ section.id }} .listicle-footer__inner {
    max-width: 1360px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 32px;
    align-items: center;
  }

  /* Links */
  #shopify-section-{{ section.id }} .listicle-footer__links {
    display: flex;
    gap: 32px;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .listicle-footer__link {
    font-family: var(--text-font-family);
    font-size: 14px;
    line-height: 1.5;
    color: rgba(253, 251, 249, 0.7);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.2s;
  }

  #shopify-section-{{ section.id }} .listicle-footer__link:hover {
    color: #fdfbf9;
  }

  #shopify-section-{{ section.id }} .listicle-footer__sep {
    width: 1px;
    height: 16px;
    background: rgba(253, 251, 249, 0.25);
    flex-shrink: 0;
  }

  /* Bottom */
  #shopify-section-{{ section.id }} .listicle-footer__bottom {
    display: flex;
    flex-direction: column;
    gap: 32px;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .listicle-footer__divider {
    width: 100%;
    height: 0;
    border: none;
    border-top: 1px solid rgba(253, 251, 249, 0.15);
    margin: 0;
  }

  #shopify-section-{{ section.id }} .listicle-footer__credits {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  #shopify-section-{{ section.id }} .listicle-footer__copyright {
    font-family: var(--text-font-family);
    font-size: 12px;
    line-height: 1.5;
    color: rgba(253, 251, 249, 0.7);
    margin: 0;
  }

  #shopify-section-{{ section.id }} .listicle-footer__payments {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .listicle-footer__payment-logo {
    height: 24px;
    width: 38px;
    object-fit: contain;
    display: block;
  }

  #shopify-section-{{ section.id }} .listicle-footer__payment-svg {
    height: 24px;
    width: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .listicle-footer {
      padding-block: 32px;
      padding-inline: 20px;
    }

    #shopify-section-{{ section.id }} .listicle-footer__links {
      flex-wrap: wrap;
      gap: 16px 24px;
    }

    #shopify-section-{{ section.id }} .listicle-footer__sep {
      display: none;
    }

    #shopify-section-{{ section.id }} .listicle-footer__credits {
      flex-direction: column;
      gap: 20px;
      align-items: center;
    }
  }
</style>

<div class="listicle-footer">
  <div class="listicle-footer__inner">

    {%- liquid
      assign has_links = false
      for i in (1..4)
        assign label_key = 'link_' | append: i | append: '_label'
        if section.settings[label_key] != blank
          assign has_links = true
        endif
      endfor
    -%}

    {%- if has_links -%}
      <nav class="listicle-footer__links" aria-label="Footer">
        {%- assign show_sep = false -%}
        {%- for i in (1..4) -%}
          {%- assign label_key = 'link_' | append: i | append: '_label' -%}
          {%- assign url_key = 'link_' | append: i | append: '_url' -%}
          {%- assign label = section.settings[label_key] -%}
          {%- assign url = section.settings[url_key] -%}
          {%- if label != blank -%}
            {%- if show_sep -%}
              <span class="listicle-footer__sep" aria-hidden="true"></span>
            {%- endif -%}
            {%- if url != blank -%}
              <a href="{{ url }}" class="listicle-footer__link">{{ label | escape }}</a>
            {%- else -%}
              <span class="listicle-footer__link">{{ label | escape }}</span>
            {%- endif -%}
            {%- assign show_sep = true -%}
          {%- endif -%}
        {%- endfor -%}
      </nav>
    {%- endif -%}

    <div class="listicle-footer__bottom">
      <hr class="listicle-footer__divider">
      <div class="listicle-footer__credits">
        <p class="listicle-footer__copyright">
          {%- if section.settings.copyright_text != blank -%}
            {{ section.settings.copyright_text | escape }}
          {%- else -%}
            &copy; {{ 'now' | date: '%Y' }} Monté. Wszystkie prawa zastrzeżone.
          {%- endif -%}
        </p>

        <div class="listicle-footer__payments">
          {%- for i in (1..4) -%}
            {%- assign logo_key = 'payment_logo_' | append: i -%}
            {%- assign logo = section.settings[logo_key] -%}
            {%- if logo != blank -%}
              {{- logo | image_url: width: 76 | image_tag: class: 'listicle-footer__payment-logo', loading: 'lazy', alt: '' -}}
            {%- endif -%}
          {%- endfor -%}

          {%- if section.settings.payment_logo_1 == blank
            and section.settings.payment_logo_2 == blank
            and section.settings.payment_logo_3 == blank
            and section.settings.payment_logo_4 == blank -%}
            <span class="listicle-footer__payment-svg" aria-label="Visa">
              <svg width="38" height="24" viewBox="0 0 38 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect width="38" height="24" rx="4" fill="rgba(255,255,255,0.08)"/>
                <text x="19" y="16" font-family="Arial, sans-serif" font-size="11" font-weight="700" fill="#ffffff" text-anchor="middle" letter-spacing="1">VISA</text>
              </svg>
            </span>
            <span class="listicle-footer__payment-svg" aria-label="Mastercard">
              <svg width="38" height="24" viewBox="0 0 38 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect width="38" height="24" rx="4" fill="rgba(255,255,255,0.08)"/>
                <circle cx="15" cy="12" r="6" fill="#eb001b" opacity="0.9"/>
                <circle cx="23" cy="12" r="6" fill="#f79e1b" opacity="0.9"/>
                <path d="M19 7.27A6 6 0 0 1 22.73 12 6 6 0 0 1 19 16.73 6 6 0 0 1 15.27 12 6 6 0 0 1 19 7.27Z" fill="#ff5f00" opacity="0.9"/>
              </svg>
            </span>
            <span class="listicle-footer__payment-svg" aria-label="Przelewy24">
              <svg width="38" height="24" viewBox="0 0 38 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect width="38" height="24" rx="4" fill="rgba(255,255,255,0.08)"/>
                <text x="19" y="16" font-family="Arial, sans-serif" font-size="9" font-weight="700" fill="#ffffff" text-anchor="middle">P24</text>
              </svg>
            </span>
            <span class="listicle-footer__payment-svg" aria-label="BLIK">
              <svg width="38" height="24" viewBox="0 0 38 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect width="38" height="24" rx="4" fill="rgba(255,255,255,0.08)"/>
                <text x="19" y="16" font-family="Arial, sans-serif" font-size="9" font-weight="700" fill="#ffffff" text-anchor="middle">blik</text>
              </svg>
            </span>
          {%- endif -%}
        </div>
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Listicle – Footer",
  "class": "shopify-section--listicle-footer",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Links"
    },
    {
      "type": "text",
      "id": "link_1_label",
      "label": "Link 1 label",
      "default": "Polityka prywatności"
    },
    {
      "type": "url",
      "id": "link_1_url",
      "label": "Link 1 URL"
    },
    {
      "type": "text",
      "id": "link_2_label",
      "label": "Link 2 label",
      "default": "Regulamin sklepu"
    },
    {
      "type": "url",
      "id": "link_2_url",
      "label": "Link 2 URL"
    },
    {
      "type": "text",
      "id": "link_3_label",
      "label": "Link 3 label",
      "default": "Polityka wysyłki"
    },
    {
      "type": "url",
      "id": "link_3_url",
      "label": "Link 3 URL"
    },
    {
      "type": "text",
      "id": "link_4_label",
      "label": "Link 4 label",
      "default": "Polityka zwrotów"
    },
    {
      "type": "url",
      "id": "link_4_url",
      "label": "Link 4 URL"
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "info": "Leave blank to use automatic year"
    },
    {
      "type": "header",
      "content": "Payment logos",
      "info": "Upload logos to replace the default placeholders. Recommended size: 76×48px."
    },
    {
      "type": "image_picker",
      "id": "payment_logo_1",
      "label": "Logo 1 (Visa)"
    },
    {
      "type": "image_picker",
      "id": "payment_logo_2",
      "label": "Logo 2 (Mastercard)"
    },
    {
      "type": "image_picker",
      "id": "payment_logo_3",
      "label": "Logo 3 (Przelewy24)"
    },
    {
      "type": "image_picker",
      "id": "payment_logo_4",
      "label": "Logo 4 (Blik)"
    }
  ],
  "presets": [
    {
      "name": "Listicle – Footer"
    }
  ]
}
{% endschema %}
