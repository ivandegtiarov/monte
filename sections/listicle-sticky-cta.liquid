<style>
  #lsc-bar-{{ section.id }} {
    display: none;
  }

  @media screen and (max-width: 899px) {
    #lsc-bar-{{ section.id }} {
      display: block;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 200;
      background: #ffffff;
      border-top: 1px solid rgba(24, 33, 83, 0.2);
      padding: 12px 20px;
      padding-bottom: calc(12px + env(safe-area-inset-bottom, 0px));
      box-shadow: 0px -8px 30px 0px rgba(45, 38, 34, 0.07);

      transform: translateY(110%);
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      will-change: transform;
    }

    #lsc-bar-{{ section.id }}.lsc-bar--visible {
      transform: translateY(0);
    }

    #lsc-bar-{{ section.id }} .lsc-bar__button {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 44px;
      background: #232e71;
      color: #fdfbf9;
      border-radius: 999px;
      border: none;
      cursor: pointer;
      font-family: var(--text-font-family);
      font-size: 14px;
      font-weight: 600;
      line-height: 1.5;
      text-transform: uppercase;
      text-decoration: none;
      transition: opacity 0.2s;
      white-space: nowrap;
    }

    #lsc-bar-{{ section.id }} .lsc-bar__button:hover {
      opacity: 0.9;
    }
  }
</style>

<div id="lsc-bar-{{ section.id }}" role="region" aria-label="Sticky CTA" aria-hidden="true">
  {%- if section.settings.button_label != blank -%}
    {%- if section.settings.button_url != blank -%}
      <a href="{{ section.settings.button_url }}" class="lsc-bar__button">
        {{- section.settings.button_label | escape -}}
      </a>
    {%- else -%}
      <button type="button" class="lsc-bar__button">
        {{- section.settings.button_label | escape -}}
      </button>
    {%- endif -%}
  {%- endif -%}
</div>

<script>
(function () {
  'use strict';

  var SHOW_THRESHOLD = 30; /* % of page scrolled before bar appears */

  function init() {
    var barEl = document.getElementById('lsc-bar-{{ section.id }}');
    if (!barEl) return;

    if (window.matchMedia('(min-width: 900px)').matches) return;

    var state = { triggerActive: false, hideActive: false };

    function update() {
      var shouldShow = state.triggerActive && !state.hideActive;
      barEl.classList.toggle('lsc-bar--visible', shouldShow);
      barEl.setAttribute('aria-hidden', shouldShow ? 'false' : 'true');
    }

    /* Appears when user has scrolled >= 30% of the page */
    function onScroll() {
      var scrollTop = window.scrollY || document.documentElement.scrollTop;
      var docHeight = document.documentElement.scrollHeight - window.innerHeight;
      var pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
      var next = pct >= SHOW_THRESHOLD;
      if (next !== state.triggerActive) {
        state.triggerActive = next;
        update();
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    /* Hides when LV3 Product CTA section enters or is scrolled past */
    var hideSection = document.querySelector('.lv3-product-cta-wrapper');
    if (hideSection) {
      var obsHide = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          state.hideActive = entry.isIntersecting || entry.boundingClientRect.top < 0;
          update();
        });
      }, { threshold: 0 });

      obsHide.observe(hideSection);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

{% schema %}
{
  "name": "Listicle – Sticky CTA",
  "class": "shopify-section--listicle-sticky-cta",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Sprawdź dostępność →"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Listicle – Sticky CTA"
    }
  ]
}
{% endschema %}
