        "maison_content_card_GTNTiX": {
          "type": "maison-content-card",
          "settings": {
            "title": "Zasypiaj szybciej. **Budź się wypoczęta.**",
            "body": "Monté eliminuje rozpraszające światło i otula twarz 100% jedwabiem, dając mózgowi sygnał, że czas na głęboki sen.",
            "feature_1": "Pełny blackout, całkowita ciemność od pierwszej nocy",
            "feature_2": "Jedwab 22 momme który nie zostawia zalamów i nie wchłania kosmetyków",
            "feature_3": "Regulowany rzep trzyma się pewnie przez całą noc, bez ucisku na skronie",
            "desktop_padding_top": 0,
            "desktop_padding_bottom": 0,
            "desktop_margin_top": 0,
