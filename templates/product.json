        "maison_content_card_GTNTiX": {
          "type": "maison-content-card",
          "settings": {
            "title": "Zasypiaj szybciej. **Budź się wypoczęta.**",
            "body": "Monté eliminuje rozpraszające światło i otula twarz jedwabiem 22 momme, dając mózgowi sygnał, że czas na głęboki sen.",
