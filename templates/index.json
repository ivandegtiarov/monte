    "faq_accordion_mbP7Rx": {
      "type": "faq-accordion",
      "blocks": {
        "faq_item_xbdW9w": {
          "type": "faq_item",
          "settings": {
            "question": "Will it actually block light?",
            "answer": "<p>Yes. The Monté sleep mask is designed with a contoured shape and blackout-grade fabric that blocks 100% of light — even in bright rooms or on early-morning flights.</p>"
          }
        },
        "faq_item_69NqLp": {
          "type": "faq_item",
          "settings": {
            "question": "I hate tight masks. Will this press on my eyes?",
            "answer": "<p>No. The mask uses a 3D contoured shell that sits away from your eyelids entirely, so there's no pressure on your eyes — even if you're a side sleeper.</p>"
          }
        },
        "faq_item_76AWdt": {
          "type": "faq_item",
          "settings": {
            "question": "Will it stay in place if I move at night?",
            "answer": "<p>Yes. The adjustable elastic band is designed to hold the mask comfortably in place through the night, whether you sleep on your back, side, or stomach.</p>"
          }
        },
        "faq_item_3Teqxk": {
          "type": "faq_item",
          "settings": {
            "question": "What does \"22-momme silk\" mean, and why does it matter?",
            "answer": "<p>Momme (mm) is the weight and density measure for silk. 22mm is considered premium — it's heavier, more durable, and feels noticeably softer than lower-grade silks used in most sleep masks.</p>"
          }
        },
        "faq_item_GRTGb6": {
