{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
MAISON: BUNDLE BLOCK
----------------------------------------------------------------------------------------------------------------------
Supported variables:
* block: the block object
* product: the current product
* product_form_id: the product form ID
{%- endcomment -%}

{%- liquid
  assign mb = block.settings
  assign color_products = mb.color_products
  assign bundle_2_product = mb.bundle_2_product
  assign bundle_3_product = mb.bundle_3_product
  assign r1v = product.selected_or_first_available_variant
-%}

{%- comment -%} Build JSON product data for JS {%- endcomment -%}
{%- capture mb_products_json -%}[
  {%- for cp in color_products -%}
    {%- assign cv = cp.selected_or_first_available_variant -%}
    {
      "id": {{ cv.id | json }},
      "title": {{ cp.title | json }},
      "price": {{ cv.price }},
      "comparePrice": {{ cv.compare_at_price | default: 0 }},
      "image": {{ cp.featured_image | image_url: width: 64 | json }},
      "url": {{ cp.url | json }}
    }{% unless forloop.last %},{% endunless %}
  {%- endfor -%}
]{%- endcapture -%}

<style>
  /* ── Wrapper ── */
  .mb {
    display: flex; flex-direction: column; gap: 20px;
    margin-top: {{ mb.mobile_margin_top }}px;
    margin-bottom: {{ mb.mobile_margin_bottom }}px;
    padding-top: {{ mb.mobile_padding_top }}px;
    padding-bottom: {{ mb.mobile_padding_bottom }}px;
  }
  @media screen and (min-width: 750px) {
    .mb {
      gap: 40px;
      margin-top: {{ mb.desktop_margin_top }}px;
      margin-bottom: {{ mb.desktop_margin_bottom }}px;
      padding-top: {{ mb.desktop_padding_top }}px;
      padding-bottom: {{ mb.desktop_padding_bottom }}px;
    }
  }

  /* ── Color Picker ── */
  .mb-colors__label { display: flex; gap: 8px; align-items: center; font-family: "PP Mori", sans-serif; font-size: 12px; font-weight: 600; color: #182153; line-height: 1.5; opacity: .5; }
  .mb-colors__swatches { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; }
  .mb-colors__swatch {
    display: block; width: 48px; height: 48px; border-radius: 8px;
    overflow: hidden; border: 2px solid #F8F1E9; background: #fdfbf9;
    cursor: pointer; text-decoration: none; transition: border-color .15s;
  }
  .mb-colors__swatch img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .mb-colors__swatch--active { border-color: #232e71; }
  @media screen and (min-width: 750px) {
    .mb-colors__swatch { width: 56px; height: 56px; border-radius: 12px; }
  }

  /* ── Bundle rows ── */
  .mb-sets__label { display: flex; gap: 8px; align-items: center; font-family: "PP Mori", sans-serif; font-size: 12px; font-weight: 600; color: #182153; line-height: 1.5; opacity: .5; }
  .mb-sets { display: flex; flex-direction: column; gap: 12px; }
  .mb-row { position: relative; }

  /* Tab badge */
  .mb-row__tab {
    position: absolute; top: -10px; right: 11px;
    display: flex; align-items: flex-start; pointer-events: none; z-index: 1;
  }
  .mb-row__tab-corner { width: 9px; height: 9px; background: #141a3f; clip-path: polygon(100% 0, 0 100%, 100% 100%); }
  .mb-row__tab-corner--right { clip-path: polygon(0 0, 0 100%, 100% 100%); }
  .mb-row__tab-label {
    background: #232e71; color: #fdfbf9;
    font-family: "PP Neue Montreal Mono", monospace; font-size: 10px; font-weight: 500;
    letter-spacing: 1px; text-transform: uppercase; line-height: 1.5;
    padding: 0 12px; height: 20px; display: flex; align-items: center; border-radius: 0 0 8px 8px;
  }
  @media screen and (min-width: 750px) { .mb-row__tab { right: 19px; } }

  /* Card shell */
  .mb-card {
    border-radius: 8px; border: 2px solid #F8F1E9;
    background: #fdfbf9; width: 100%; overflow: hidden;
    transition: border-color .25s ease, background .25s ease;
  }
  .mb-card--selected { border-color: #232e71; background: #e8e9f0; }
  @media screen and (min-width: 750px) { .mb-card { border-radius: 12px; } }

  /* Card header row */
  .mb-card__top {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px; gap: 12px; cursor: pointer;
  }
  @media screen and (min-width: 750px) { .mb-card__top { padding: 12px 20px; } }

  .mb-card__left { display: flex; flex-direction: column; }
  .mb-card__title-row { display: flex; align-items: center; gap: 12px; }
  .mb-card__title { font-family: "PP Mori", sans-serif; font-size: 14px; font-weight: 600; color: #182153; line-height: 1.5; white-space: nowrap; }
  .mb-card__badge-disc {
    display: inline-flex; align-items: center; height: 20px; padding: 0 12px;
    background: rgba(47,107,87,.08); border-radius: 999px;
    font-family: "PP Neue Montreal Mono", monospace; font-size: 10px; font-weight: 500;
    letter-spacing: 1px; text-transform: uppercase; color: #2f6b57; line-height: 1.5; white-space: nowrap;
  }
  .mb-card__save { font-family: "PP Mori", sans-serif; font-size: 12px; font-weight: 600; color: #182153; opacity: .5; line-height: 1.5; white-space: nowrap; }

  .mb-card__right { display: flex; flex-direction: column; align-items: flex-end; white-space: nowrap; }
  .mb-card__price-row { display: flex; gap: 4px; align-items: baseline; }
  .mb-card__price { font-family: "PP Mori", sans-serif; font-size: 14px; font-weight: 600; color: #182153; line-height: 1.5; }
  .mb-card__price-each { font-family: "PP Mori", sans-serif; font-size: 14px; font-weight: 600; color: rgba(24,33,83,.5); line-height: 1.5; }
  .mb-card__compare { font-family: "PP Mori", sans-serif; font-size: 12px; font-weight: 600; color: #182153; opacity: .5; line-height: 1.5; text-decoration: line-through; }

  /* Expanded body — height animated via JS */
  .mb-card__body {
    display: flex; flex-direction: column; gap: 8px;
    padding: 0 12px 0 12px;
    overflow: hidden; max-height: 0;
    opacity: 0;
    transition: max-height .38s cubic-bezier(.32,.72,0,1), opacity .25s ease, padding-bottom .38s cubic-bezier(.32,.72,0,1);
  }
  .mb-card--selected .mb-card__body { opacity: 1; }
  @media screen and (min-width: 750px) { .mb-card__body { padding-left: 20px; padding-right: 20px; } }
  .mb-card__divider { border: none; border-top: 1px solid rgba(24,33,83,.12); margin: 0 0 4px; }

  .mb-card__item { display: flex; align-items: center; gap: 12px; }
  .mb-card__item-img { width: 32px; height: 32px; border-radius: 4px; object-fit: cover; flex-shrink: 0; }
  .mb-card__item-img-placeholder { width: 32px; height: 32px; border-radius: 4px; flex-shrink: 0; background: #c4c7d9; }
  .mb-card__item-name { font-family: "PP Mori", sans-serif; font-size: 12px; font-weight: 600; color: #182153; line-height: 1.5; flex: 1; }

  /* Slot rows */
  .mb-card__slot { display: flex; align-items: center; }
  .mb-card__slot-chosen { display: flex; align-items: center; gap: 12px; width: 100%; }
  .mb-card__slot-chosen[hidden] { display: none; }
  .mb-card__slot-empty { display: flex; align-items: center; gap: 12px; }
  .mb-card__slot-clear {
    margin-left: auto; width: 28px; height: 28px; border-radius: 999px;
    border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .mb-card__color-btn {
    display: inline-flex; align-items: center; justify-content: center;
    height: 28px; padding: 0 16px;
    background: #232e71; border-radius: 999px; border: none; cursor: pointer;
    font-family: "PP Mori", sans-serif; font-size: 10px; font-weight: 600;
    color: #fdfbf9; text-transform: uppercase; letter-spacing: .5px; white-space: nowrap;
  }
  .mb-card__color-thumb {
    width: 32px; height: 32px; border-radius: 4px; background: #c4c7d9;
    overflow: hidden; flex-shrink: 0;
  }
  .mb-card__color-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* Footer strip — always visible below card body */
  .mb-card__footer {
    padding: 6px 12px; text-align: center;
    font-family: "PP Mori", sans-serif; font-size: 11px; font-weight: 600;
    color: #42403e; line-height: 1.5;
    background: #f8f1e9;
    border-top: 1px solid #F8F1E9;
    border-radius: 0 0 6px 6px;
    transition: background .25s ease, border-color .25s ease, color .25s ease;
  }
  /* Selected state: blue tint footer */
  .mb-card--selected .mb-card__footer {
    background: #c4c7d9; color: #182153;
    border-top: none;
  }


  /* ── ATC button ── */
  .mb-atc {
    display: flex; align-items: center; justify-content: center;
    width: 100%; padding: 14px 32px; gap: 8px;
    background: #232e71; border-radius: 999px; border: none; cursor: pointer;
    font-family: "PP Mori", sans-serif; font-size: 12px; font-weight: 600;
    color: #fdfbf9; text-transform: uppercase; letter-spacing: .5px;
    line-height: 1.5; white-space: nowrap; position: relative;
    transition: opacity .15s ease;
  }
  .mb-atc:disabled { opacity: .6; cursor: wait; }
  @media screen and (min-width: 750px) { .mb-atc { font-size: 14px; gap: 12px; } }
  .mb-atc__inner { display: flex; align-items: center; gap: 8px; }
  @media screen and (min-width: 750px) { .mb-atc__inner { gap: 12px; } }
  .mb-atc__icon { flex-shrink: 0; }
  .mb-atc__dot {
    width: 4px; height: 4px; border-radius: 999px;
    background: rgba(253,251,249,.5); flex-shrink: 0;
  }
  .mb-atc__spinner {
    display: flex; align-items: center; justify-content: center;
  }
  .mb-atc__spinner svg { animation: mb-spin .75s linear infinite; }
  @keyframes mb-spin { to { transform: rotate(360deg); } }

  /* Stock bar */
  .mb-stock { display: flex; align-items: center; gap: 20px; }
  .mb-stock__dot { width: 8px; height: 8px; border-radius: 999px; flex-shrink: 0; background: #8a2f3a; box-shadow: 0 0 0 3px rgba(138,47,58,.25); animation: mb-pulse 2s ease-in-out infinite; }
  @keyframes mb-pulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(138,47,58,.25); }
    50% { box-shadow: 0 0 0 6px rgba(138,47,58,.0); }
  }
  .mb-stock__label { font-family: "PP Mori", sans-serif; font-size: 12px; font-weight: 600; color: #182153; line-height: 1.5; white-space: nowrap; }
  @media screen and (min-width: 750px) { .mb-stock__label { font-size: 14px; } }
  .mb-stock__bar { flex: 1; height: 4px; border-radius: 999px; background: rgba(24,33,83,.08); overflow: hidden; }
  .mb-stock__fill { height: 100%; border-radius: 999px; background: #8a2f3a; }

  /* ── Popup overlay ── */
  .mb-popup-overlay {
    position: fixed; inset: 0; z-index: 10000;
    background: rgba(24,33,83,.7); backdrop-filter: blur(4px);
    display: flex; align-items: flex-end; justify-content: center;
    opacity: 0; visibility: hidden; pointer-events: none;
    transition: opacity .35s ease, visibility .35s ease;
  }
  .mb-popup-overlay.is-open {
    opacity: 1; visibility: visible; pointer-events: auto;
  }
  @media screen and (min-width: 750px) {
    .mb-popup-overlay { align-items: stretch; justify-content: flex-end; padding: 8px; }
  }

  /* Mobile: slide up from bottom */
  .mb-popup {
    background: #fff; width: 100%;
    border-radius: 16px 16px 0 0; max-height: 90vh;
    display: flex; flex-direction: column; overflow: hidden;
    transform: translateY(100%);
    transition: transform .4s cubic-bezier(.32,.72,0,1);
    will-change: transform;
  }
  .mb-popup-overlay.is-open .mb-popup { transform: translateY(0); }

  /* Desktop: slide in from right */
  @media screen and (min-width: 750px) {
    .mb-popup {
      width: 420px; border-radius: 16px; max-height: none; height: 100%;
      transform: translateX(120%);
      transition: transform .4s cubic-bezier(.32,.72,0,1);
    }
    .mb-popup-overlay.is-open .mb-popup { transform: translateX(0); }
  }

  .mb-popup__header { display: flex; align-items: center; justify-content: space-between; padding: 20px 20px 8px; }
  .mb-popup__title { font-family: "PP Pangaia", serif; font-size: 20px; font-weight: 500; color: #182153; line-height: 1.4; }
  @media screen and (min-width: 750px) { .mb-popup__title { font-size: 24px; } }
  .mb-popup__close { width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; border: none; background: none; cursor: pointer; border-radius: 8px; padding: 8px; }
  .mb-popup__list { overflow-y: auto; flex: 1; }
  .mb-popup__item { display: flex; align-items: center; gap: 16px; padding: 20px; border-bottom: 1px solid rgba(24,33,83,.08); }
  .mb-popup__img { width: 64px; height: 64px; border-radius: 12px; object-fit: cover; flex-shrink: 0; background: #fbf7f3; }
  @media screen and (min-width: 750px) { .mb-popup__img { width: 80px; height: 80px; } }
  .mb-popup__info { flex: 1; display: flex; flex-direction: column; gap: 4px; }
  .mb-popup__name { font-family: "PP Mori", sans-serif; font-size: 14px; font-weight: 600; color: #182153; line-height: 1.5; }
  @media screen and (min-width: 750px) { .mb-popup__name { font-size: 16px; } }
  .mb-popup__prices { display: flex; align-items: center; gap: 8px; }
  .mb-popup__compare { font-family: "PP Mori", sans-serif; font-size: 12px; font-weight: 600; color: #182153; opacity: .5; text-decoration: line-through; line-height: 1.5; }
  @media screen and (min-width: 750px) { .mb-popup__compare { font-size: 14px; } }
  .mb-popup__price { font-family: "PP Mori", sans-serif; font-size: 14px; font-weight: 600; color: #182153; line-height: 1.5; }
  @media screen and (min-width: 750px) { .mb-popup__price { font-size: 16px; } }
  .mb-popup__choose {
    display: inline-flex; align-items: center; justify-content: center;
    height: 32px; padding: 0 16px; background: #232e71; border-radius: 999px;
    border: none; cursor: pointer;
    font-family: "PP Mori", sans-serif; font-size: 12px; font-weight: 600;
    color: #fdfbf9; text-transform: uppercase; letter-spacing: .5px; white-space: nowrap;
  }
</style>

{%- comment -%} ── COLOR POPUP ── {%- endcomment -%}
<div class="mb-popup-overlay" id="mb-popup-{{ block.id }}" role="dialog" aria-modal="true" aria-hidden="true">
  <div class="mb-popup">
    <div class="mb-popup__header">
      <p class="mb-popup__title">{{ mb.popup_title | default: 'Choose product' }}</p>
      <button class="mb-popup__close" data-mb-close aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M2 2L14 14M14 2L2 14" stroke="#182153" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
    <div class="mb-popup__list">
      {%- for cp in color_products -%}
        {%- assign cv = cp.selected_or_first_available_variant -%}
        <div class="mb-popup__item">
          {%- if cp.featured_image -%}
            <img class="mb-popup__img" src="{{ cp.featured_image | image_url: width: 160 }}" alt="{{ cp.title | escape }}" width="80" height="80" loading="lazy">
          {%- else -%}
            <div class="mb-popup__img"></div>
          {%- endif -%}
          <div class="mb-popup__info">
            <p class="mb-popup__name">{{ cp.title }}</p>
            <div class="mb-popup__prices">
              {%- if cv.compare_at_price > cv.price -%}
                <span class="mb-popup__compare">
                  {%- if settings.currency_code_enabled -%}{{ cv.compare_at_price | money_with_currency }}{%- else -%}{{ cv.compare_at_price | money }}{%- endif -%}
                </span>
              {%- endif -%}
              <span class="mb-popup__price">
                {%- if settings.currency_code_enabled -%}{{ cv.price | money_with_currency }}{%- else -%}{{ cv.price | money }}{%- endif -%}
              </span>
            </div>
          </div>
          <button class="mb-popup__choose"
            data-mb-choose
            data-product-id="{{ cv.id }}"
            data-product-title="{{ cp.title | escape }}"
            data-product-price="{{ cv.price }}"
            data-product-compare="{{ cv.compare_at_price | default: 0 }}"
            data-product-image="{{ cp.featured_image | image_url: width: 64 }}"
            data-product-url="{{ cp.url }}">
            {{ mb.popup_choose_label | default: 'Choose' }}
          </button>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<div class="mb" {{ block.shopify_attributes }}
  data-mb-block
  data-r1-price="{{ r1v.price }}"
  data-r1-compare="{{ r1v.compare_at_price | default: 0 }}"
  data-r2-price="{{ bundle_2_product.selected_or_first_available_variant.price | default: 0 }}"
  data-r2-compare="{{ bundle_2_product.selected_or_first_available_variant.compare_at_price | default: 0 }}"
  data-r2-discount="{{ mb.row2_discount | default: 0 }}"
  data-r3-price="{{ bundle_3_product.selected_or_first_available_variant.price | default: 0 }}"
  data-r3-compare="{{ bundle_3_product.selected_or_first_available_variant.compare_at_price | default: 0 }}"
  data-r3-discount="{{ mb.row3_discount | default: 0 }}"
  data-currency-symbol="{{ cart.currency.symbol }}"
  data-currency-code="{{ cart.currency.iso_code }}">

  {%- comment -%} ── COLOR SWATCHES ── {%- endcomment -%}
  {%- if color_products.count > 0 -%}
    <div class="mb-colors">
      <div class="mb-colors__label">
        <span>{{ mb.color_label | default: 'SELECT YOUR COLOR:' }}</span>
        <span style="font-weight:375;">{{ product.title }}</span>
      </div>
      <div class="mb-colors__swatches">
        {%- for cp in color_products -%}
          <a href="{{ cp.url }}"
             class="mb-colors__swatch{% if cp.handle == product.handle %} mb-colors__swatch--active{% endif %}"
             title="{{ cp.title | escape }}"
             aria-label="{{ cp.title | escape }}"
             aria-current="{% if cp.handle == product.handle %}true{% else %}false{% endif %}">
            {%- if cp.featured_image -%}
              <img src="{{ cp.featured_image | image_url: width: 112 }}" alt="{{ cp.title | escape }}" width="56" height="56" loading="lazy">
            {%- endif -%}
          </a>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── BUNDLE SET ROWS ── {%- endcomment -%}
  <div class="mb-sets">
    <div class="mb-sets__label">
      <span>{{ mb.set_label | default: 'CHOOSE YOUR SET:' }}</span>
      <span style="font-weight:375;" data-mb-active-label>{{ mb.set_label_default | default: '1 Mask' }}</span>
    </div>

    {%- comment -%} ── ROW 1: 1 Mask (current product, always first) ── {%- endcomment -%}
    <div class="mb-row" data-mb-row="1">
      <div class="mb-card mb-card--selected" data-mb-card data-mb-slots="1">
        <div class="mb-card__top" data-mb-toggle>
          <div class="mb-card__left">
            <div class="mb-card__title-row">
              <span class="mb-card__title">{{ mb.row1_title | default: '1 Mask' }}</span>
            </div>
          </div>
          <div class="mb-card__right">
            <div class="mb-card__price-row">
              <span class="mb-card__price" data-mb-price>
                {%- if settings.currency_code_enabled -%}{{ r1v.price | money_with_currency }}{%- else -%}{{ r1v.price | money }}{%- endif -%}
              </span>
              <span class="mb-card__price-each">/ {{ mb.each_label | default: 'each' }}</span>
            </div>
            {%- if r1v.compare_at_price > r1v.price -%}
              <span class="mb-card__compare" data-mb-compare>
                {%- if settings.currency_code_enabled -%}{{ r1v.compare_at_price | money_with_currency }}{%- else -%}{{ r1v.compare_at_price | money }}{%- endif -%}
              </span>
            {%- endif -%}
          </div>
        </div>
        <div class="mb-card__body">
          <hr class="mb-card__divider">
          {%- comment -%} Slot 1: always the current product {%- endcomment -%}
          <div class="mb-card__item">
            {%- if product.featured_image -%}
              <img class="mb-card__item-img" src="{{ product.featured_image | image_url: width: 64 }}" alt="{{ product.title | escape }}" width="32" height="32" loading="lazy">
            {%- else -%}
              <div class="mb-card__item-img-placeholder"></div>
            {%- endif -%}
            <span class="mb-card__item-name">{{ product.title }}</span>
          </div>
        </div>
        {%- if mb.row1_footer != blank -%}
          <div class="mb-card__footer">{{ mb.row1_footer }}</div>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} ── ROW 2: 2 Masks ── {%- endcomment -%}
    {%- if bundle_2_product != blank -%}
      {%- assign r2v = bundle_2_product.selected_or_first_available_variant -%}
      <div class="mb-row" data-mb-row="2">
        {%- if mb.row2_tab != blank -%}
          <div class="mb-row__tab">
            <div class="mb-row__tab-corner"></div>
            <div class="mb-row__tab-label">{{ mb.row2_tab }}</div>
            <div class="mb-row__tab-corner mb-row__tab-corner--right"></div>
          </div>
        {%- endif -%}
        <div class="mb-card" data-mb-card data-mb-slots="2">
          <div class="mb-card__top" data-mb-toggle>
            <div class="mb-card__left">
              <div class="mb-card__title-row">
                <span class="mb-card__title">{{ mb.row2_title | default: '2 Masks' }}</span>
                {%- if mb.row2_badge != blank -%}
                  <span class="mb-card__badge-disc">{{ mb.row2_badge }}</span>
                {%- endif -%}
              </div>
              {%- if mb.row2_save != blank -%}
                <span class="mb-card__save">{{ mb.row2_save }}</span>
              {%- endif -%}
            </div>
            <div class="mb-card__right">
              <div class="mb-card__price-row">
                <span class="mb-card__price" data-mb-price>
                  {%- if settings.currency_code_enabled -%}{{ r2v.price | money_with_currency }}{%- else -%}{{ r2v.price | money }}{%- endif -%}
                </span>
                <span class="mb-card__price-each">/ {{ mb.each_label | default: 'each' }}</span>
              </div>
              {%- if r2v.compare_at_price > r2v.price -%}
                <span class="mb-card__compare" data-mb-compare>
                  {%- if settings.currency_code_enabled -%}{{ r2v.compare_at_price | money_with_currency }}{%- else -%}{{ r2v.compare_at_price | money }}{%- endif -%}
                </span>
              {%- endif -%}
            </div>
          </div>
          <div class="mb-card__body">
